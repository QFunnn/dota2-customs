		//"DOTA_Tooltip_ability_item_bloodstone_bonus_magical_armor"			"%+$spell_resist"
		"DOTA_Tooltip_ability_item_bloodstone_2_bonus_health_regen"				"+$hp_regen"
		"DOTA_Tooltip_ability_item_bloodstone_2_spell_amp"						"%+к урону от заклинаний"
		// "DOTA_Tooltip_ability_item_bloodstone_2_hero_lifesteal"					"%+技能吸血（英雄）"
		"DOTA_Tooltip_ability_item_bloodstone_2_spell_lifesteal"					"%+к вампиризму заклинаниями"
