		//Tiny
		"DOTA_Tooltip_ability_tiny_tree_grab_lua"												"Tree Grab"
		"DOTA_Tooltip_ability_tiny_tree_grab_lua_lore"											"Sticks and stones break all the bones, with structures sure to follow."
		"DOTA_Tooltip_ability_tiny_tree_grab_lua_Description"									"Grabs a tree to whack enemies on the head. Grants bonus attack range, attacks deal more damage and fully splash on units along the way. The tree can be thrown, to deal your attack to a unit at a distance."
		"DOTA_Tooltip_ability_tiny_tree_grab_lua_scepter_description"                           ""
