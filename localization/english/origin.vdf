		"DOTA_Tooltip_ability_item_ranged_cleave_Description"         "<h1>Passive: Scatterblast</h1>RANGED ONLY: grants %cleave_dmg%%% splash damage in %cleave_radius% radius, and %bonus_range% bonus attack range."
