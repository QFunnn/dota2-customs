		//Tidehunter
		//Timbersaw
		"DOTA_Tooltip_ability_shredder_chakram_lua"								"CHAKRAM"
		"DOTA_Tooltip_ability_shredder_chakram_lua_Description"					"Fires Timbersaw's main saw blade at the target location where it will spin in place, dealing damage in an area around it.Enemies caught in the saw blade will move more slowly for every %slow_health_percentage%%% of health missing. The blade deals damage and cuts down trees in its path when fired and retracted.While active the ability costs mana, and Timbersaw loses the ability to attack."
		"DOTA_Tooltip_ability_shredder_chakram_lua_Lore"							"The ultimate in anti-flora weaponry."
		"DOTA_Tooltip_ability_shredder_chakram_lua_Note0"							"The Chakram returns if Timbersaw depletes his mana or moves beyond %break_distance%."
		"DOTA_Tooltip_ability_shredder_chakram_lua_radius"							"RADIUS:"
		"DOTA_Tooltip_ability_shredder_chakram_lua_pass_damage"					"PASS DAMAGE:"
		"DOTA_Tooltip_ability_shredder_chakram_lua_damage_per_second"				"DAMAGE PER SECOND:"
		"DOTA_Tooltip_ability_shredder_chakram_lua_slow"							"%SLOW:"
		"DOTA_Tooltip_ability_shredder_chakram_lua_mana_per_second"				"MANA COST PER SECOND:"
		// "DOTA_Tooltip_ability_shredder_chakram_lua_scepter_description"			"提供第二个锯齿飞轮。"
		"DOTA_Tooltip_ability_shredder_chakram_lua_return"							"Return Chakram"
		"DOTA_Tooltip_ability_shredder_chakram_lua_return_Description"				"Returns the Chakram to Timbersaw."
		"DOTA_Tooltip_ability_shredder_chakram_2_lua"						"Second Chakram"
		"DOTA_Tooltip_ability_shredder_chakram_2_lua_Description"			"Fires a secondary saw blade at the target location where it will spin in place, dealing damage in an area around it.Additionally, for each 5% of health missing, enemies caught in the saw blade move more slowly. The blade deals damage and cuts down trees in its path when fired and retracted.While active the ability costs mana, and Timbersaw loses the ability to attack."
		"DOTA_Tooltip_ability_shredder_chakram_2_lua_Lore"					"Cut cut cut cut cut cut cut cut cut cut cut!"
		"DOTA_Tooltip_ability_shredder_chakram_2_lua_Note0"					"The Chakram returns if Timbersaw depletes his mana or moves beyond %break_distance%."
		"DOTA_Tooltip_ability_shredder_chakram_2_lua_Note1"					"Slow effects from two chakrams do not stack."
		"DOTA_Tooltip_ability_shredder_chakram_2_lua_radius"					"RADIUS:"
		"DOTA_Tooltip_ability_shredder_chakram_2_lua_pass_damage"			"PASS DAMAGE:"
		"DOTA_Tooltip_ability_shredder_chakram_2_lua_damage_per_second"		"DAMAGE PER SECOND:"
		"DOTA_Tooltip_ability_shredder_chakram_2_lua_slow"					"%SLOW:"
		"DOTA_Tooltip_ability_shredder_chakram_2_lua_mana_per_second"		"MANA COST PER SECOND:"
		"DOTA_Tooltip_ability_shredder_chakram_lua_2_return"					"Return Chakram"
		"DOTA_Tooltip_ability_shredder_chakram_lua_2_return_Description"		"Returns the Chakram to Timbersaw."
		"DOTA_Tooltip_modifier_shredder_chakram_slow_lua"							"CHAKRAM"
		"DOTA_Tooltip_modifier_shredder_chakram_slow_lua_Description"				"Taking damage over time and being slowed by the Chakram."
		"DOTA_Tooltip_modifier_shredder_chakram_disarm_lua"						"Chakram Disarm"
		"DOTA_Tooltip_modifier_shredder_chakram_disarm_lua_Description"			"You cannot attack while the Chakram is airborne."
		//Tinker
		"DOTA_Tooltip_ability_tinker_heat_seeking_missile_lua"									"Heat-Seeking Missile"
		"DOTA_Tooltip_ability_tinker_heat_seeking_missile_lua_Description"						"Launches rockets at the nearest visible heroes within %radius% range."
		"DOTA_Tooltip_ability_tinker_heat_seeking_missile_lua_Lore"								"The last contraption Boush was able to save was a retrofitted rocket launcher with a homing mechanism."
		"DOTA_Tooltip_ability_tinker_heat_seeking_missile_lua_damage"							"DAMAGE:"
		"DOTA_Tooltip_ability_tinker_heat_seeking_missile_lua_targets"							"TARGETS:"
