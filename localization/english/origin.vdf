		"DOTA_Tooltip_modifier_tiny_grab_lua_Description"										"Attacks deal increased and splash damage."
		"DOTA_Tooltip_ability_tiny_tree_throw_lua"												"Tree Throw"
		"DOTA_Tooltip_ability_tiny_tree_throw_lua_Description"									"Throws the tree at the target unit, proccing your attack on it and splashing damage around the target."
