		"DOTA_Tooltip_ability_invoker_sun_strike_lua"								"Sun Strike"
		"DOTA_Tooltip_ability_invoker_sun_strike_lua_Description"					"Sends a catastrophic ray of fierce energy from the sun at any targeted location, incinerating all enemies standing beneath it once it reaches the earth. However this damage is spread evenly over all enemies hit."
		"DOTA_Tooltip_ability_invoker_sun_strike_lua_area_of_effect"				"RADIUS:"
		"DOTA_Tooltip_ability_invoker_sun_strike_lua_delay"							"DELAY:"
		"DOTA_Tooltip_ability_invoker_sun_strike_lua_damage"						"DAMAGE:"
		"DOTA_Tooltip_ability_invoker_sun_strike_lua_Lore"							"Harlek's Incantation of Incineration."
		"DOTA_Tooltip_ability_invoker_sun_strike_lua_Note0"							"Gives vision of the target area before the strike."
		"DOTA_Tooltip_ability_invoker_sun_strike_lua_Note1"							"Only half damage when casting cataclysm."

		"DOTA_Tooltip_ability_invoker_deafening_blast_lua"							"Deafening Blast"
		"DOTA_Tooltip_ability_invoker_deafening_blast_lua_Description"				"Invoker unleashes a mighty sonic wave in front of him, dealing damage to any enemy unit it collides with based on the level of <font color='#cabe68'>Exort</font>. The sheer impact from the blast is enough to knock those enemy units back for a duration based on the level of <font color='#7998b5'>Quas</font>, then disarm their attacks for a duration based on the level of <font color='#d671a9'>Wex</font>."
		"DOTA_Tooltip_ability_invoker_deafening_blast_lua_damage"					"DAMAGE:"
		"DOTA_Tooltip_ability_invoker_deafening_blast_lua_knockback_duration"		"KNOCKBACK DURATION:"
		"DOTA_Tooltip_ability_invoker_deafening_blast_lua_disarm_duration"			"DISARM DURATION:"
		"DOTA_Tooltip_modifier_invoker_deafening_blast_lua_knockback"				"Deafening Blast Knockback"
		"DOTA_Tooltip_modifier_invoker_deafening_blast_lua_knockback_Description"	"Reeling back from the deafening blast."
		"DOTA_Tooltip_modifier_invoker_deafening_blast_lua_disarm"					"Deafening Blast Disarm"
		"DOTA_Tooltip_modifier_invoker_deafening_blast_lua_disarm_Description"		"Cannot attack."
		"DOTA_Tooltip_ability_invoker_deafening_blast_lua_Lore"						"Buluphont's Aureal Incapacitator."
		"DOTA_Tooltip_ability_invoker_deafening_blast_lua_travel_distance"			"TRAVEL DISTANCE:"
