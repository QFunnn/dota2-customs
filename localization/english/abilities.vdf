"DOTA_Tooltip_ability_faceless_void_time_lock_lua"									"Time Lock"
"DOTA_Tooltip_ability_faceless_void_time_lock_lua_Description"						"Adds the chance for an attack to lock an enemy unit in time while attacking it a second time."
"DOTA_Tooltip_ability_faceless_void_time_lock_lua_Lore"								"The strike of the Faceless Void lands with dimension shifting force."
"DOTA_Tooltip_ability_faceless_void_time_lock_lua_chance_pct"						"%Trigger Chance: "
