        "DOTA_Tooltip_ability_frostivus2018_weaver_geminate_attack_custom_arrow_count"                                            "<font color='#70EA72'>BONUS TARGETS:</font>"
        "DOTA_Tooltip_ability_weaver_the_swarm_shard_description"                                                                 ""
        "DOTA_Tooltip_ability_weaver_shukuchi_shard_Description"                                                                  "Applies mark on enemies that this ability dealt damage to. Marked enemies within 1200 radius also receive bonus attacks from Geminate Attack. Mark lasts 6 sec."
        "DOTA_Tooltip_ability_weaver_time_lapse_ability_note"                                                                     "Ability has reduced cooldown.<br><br><font color='#F00'>Ability disables 5 seconds before main duel time ends.</font>"
        "DOTA_Tooltip_ability_weaver_time_lapse_scepter_description"                                                               "123"
        "DOTA_Tooltip_ability_weaver_shukuchi_ability_note"                                                                       "Passively increases physical and magical lifesteal by 30%."
        "DOTA_Tooltip_ability_frostivus2018_weaver_geminate_attack_custom_ability_note"                                           "If you have Geminate Attack you cannot get Arcane orb!"
