        "DOTA_Tooltip_ability_skeleton_king_hellfire_blast_shard_description"                                                    "Critical strike deals %wraith_crit_bonus%%% more damage in wraith form."
        "DOTA_Tooltip_modifier_hero_unique_modifier_skeleton_king_hellfire_blast"                                                "Mortal Strike"
        "DOTA_Tooltip_modifier_hero_unique_modifier_skeleton_king_hellfire_blast_Description"                                    "Critical strike readiness status."
