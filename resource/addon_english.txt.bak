        "DOTA_Tooltip_ability_necrolyte_heartstopper_aura_lua_hero_multiplier"                                                    "REGEN MULTIPLIER FOR HERO KILL:"
        "DOTA_Tooltip_ability_necrolyte_heartstopper_aura_lua_scepter_description"                                                "Adds 30% of owner's current health regen to health reduction."
        "DOTA_Tooltip_modifier_necrolyte_heartstopper_aura_lua_counter"                                                           "Heartstopper Regen"
        "DOTA_Tooltip_modifier_necrolyte_heartstopper_aura_lua_counter_Description"                                               "Health regen temporarily increased by %fMODIFIER_PROPERTY_HEALTH_REGEN_CONSTANT%, and mana regen by %fMODIFIER_PROPERTY_MANA_REGEN_CONSTANT%."
        "DOTA_Tooltip_modifier_ghost_shroud_custom_active"                                                                        "Ghost Shroud"
        "DOTA_Tooltip_modifier_ghost_shroud_custom_active_Description"                                                            "Slows nearby enemies, takes more magical damage and restores mana and health faster."
