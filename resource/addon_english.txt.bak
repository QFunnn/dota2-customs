      "VOTES_LIST_LAST_DUEL_1"                                                                                                        "Agree"
      "VOTES_LIST_LAST_DUEL_1_desc"                                                                                                   "You agree to last duel."
      "VOTES_LIST_LAST_DUEL_desc"                                                                                                      "Do you agree to participate in last duel? Mode of 5 rounds, winner of 3 wins.<br>To begin, every player must agree.<br>At start of last duel you receive starting bonuses."
      "VOTES_LIST_SETTINGS_STATE"                                                                                                          "Settings stage vote"
      "VOTES_LIST_SETTINGS_STATE_0"                                                                                                        "Decline"
      "VOTES_LIST_SETTINGS_STATE_0_desc"                                                                                                   "Skip settings stage. Standard settings will be used for game."
      "VOTES_LIST_SETTINGS_STATE_1"                                                                                                        "Agree"
      "VOTES_LIST_SETTINGS_STATE_1_desc"                                                                                                   "You agree to configure game difficulty."
      "VOTES_LIST_SETTINGS_STATE_desc"                                                                                                     "Do you want to configure game difficulty?"
      "VOTES_LIST_DIFFICULT_SELECTION"                                                                                                          "Game settings vote"
      "VOTES_LIST_DIFFICULT_SELECTION_desc"                                                                                                     "Play with default settings or customize manually?"
      "VOTES_LIST_DIFFICULT_SELECTION_0"                                                                                                        "Default"
      "VOTES_LIST_DIFFICULT_SELECTION_0_desc"                                                                                                   "Start with preselected default settings.<br><br>Banning stage duration %BANNING_STATE_DURATION%<br>Pick stage duration %PICK_STATE_DURATION%<br>Starting smoke count %PLAYER_INIT_SMOKES%<br>Hero reroll count %PLAYER_INIT_REROLLS%<br>Bonus armor for late rounds %CREEP_BONUS_ARMOR_PER_LATE_ROUND%<br>Bonus magic resistance for late rounds %CREEP_BONUS_MAGIC_RESISTANCE_PER_LATE_ROUND%"
      "VOTES_LIST_DIFFICULT_SELECTION_1"                                                                                                        "Custom"
      "VOTES_LIST_DIFFICULT_SELECTION_1_desc"                                                                                                   "You configure each parameter through mini-votes.<br><br>Has some unique settings not available in defaults."
      "VOTES_LIST_BANS_DURATION"                                                                                                          "Banning stage duration"
      "VOTES_LIST_PICKS_DURATION"                                                                                                         "Pick stage duration"
