        "DOTA_Tooltip_ability_zuus_lightning_bolt_custom_Lore"                                                                    "Stunning punishment for rebellious heathens."
        "DOTA_Tooltip_ability_zuus_lightning_bolt_custom_Note0"                                                                   "Interrupts channeled spells."
        "DOTA_Tooltip_ability_special_bonus_unique_zeus_5"                                                                        "+1 Lightning Bolt Charge"
        "DOTA_Tooltip_ability_zuus_cloud_custom"                                                                                  "Nimbus"
        "DOTA_Tooltip_ability_zuus_cloud_custom_Description"                                                                      "Creates storm cloud anywhere on map that automatically strikes nearby enemies with Lightning Bolt ability."
