        "DOTA_Tooltip_ability_ability_phoenix_supernova_max_hero_attacks"                                                         "ATTACKS TO DESTROY:"
        "DOTA_Tooltip_ability_ability_phoenix_supernova_max_hero_attacks_scepter"                                                 "ATTACKS TO DESTROY:"
        "DOTA_Tooltip_ability_ability_phoenix_supernova_cast_range_tooltip_scepter"                                               "CAST RANGE:"
        "DOTA_Tooltip_modifier_ability_phoenix_supernova_hiding"                                                                  "Sun Form"
        "DOTA_Tooltip_modifier_ability_phoenix_supernova_hiding_Description"                                                      "Burns enemies before being reborn."
        "DOTA_Tooltip_modifier_ability_phoenix_supernova"                                                                         "Sun Form"
        "DOTA_Tooltip_modifier_ability_phoenix_supernova_Description"                                                             "Burns enemies before being reborn."
        "DOTA_Tooltip_modifier_ability_phoenix_supernova_debuff"                                                                  "Solar Burn"
        "DOTA_Tooltip_modifier_ability_phoenix_supernova_debuff_Description"                                                      "Taking %dMODIFIER_PROPERTY_TOOLTIP% damage per second."
        "DOTA_Tooltip_ability_ability_phoenix_supernova_ability_note"                                                             "Ability has reduced cooldown.<br><br><font color='#F00'>Ability is disabled 5 seconds before main duel time ends.</font>"
        "DOTA_Tooltip_ability_phoenix_sun_ray_ability_note"                                                                      ""
      //=================================================================================================================
      // Pudge
      //=================================================================================================================
        "DOTA_Tooltip_ability_pudge_flesh_heap_lua"                                                                               "Flesh Heap"
        "DOTA_Tooltip_ability_pudge_flesh_heap_lua_Description"                                                                   "Guarantees blocking part of damage from any attack. Also grants bonus strength for every enemy that dies within the radius, and for every kill you make at any range — enemy heroes grant several times more. Bonuses accumulate from the start of the game, but are granted only after learning the ability."
        "DOTA_Tooltip_ability_pudge_flesh_heap_lua_Lore"                                                                          "Butcher introduces new concept in defense sphere, and its name is 'Shield of Bones and Flesh.'"
        "DOTA_Tooltip_ability_pudge_flesh_heap_lua_strength_per_kill"                                                             "STRENGTH BONUS:"
        "DOTA_Tooltip_ability_pudge_flesh_heap_lua_aura_radius"                                                                   "STRENGTH GAIN RADIUS:"
        "DOTA_Tooltip_modifier_pudge_flesh_heap_lua"                                                                              "Flesh Heap"
        "DOTA_Tooltip_modifier_pudge_flesh_heap_lua_Description"                                                                  "Adds %0fMODIFIER_PROPERTY_STATS_STRENGTH_BONUS% strength"
        "DOTA_Tooltip_modifier_pudge_flesh_heap_lua_block"                                                                        "Flesh Heap Block"
        "DOTA_Tooltip_modifier_pudge_flesh_heap_lua_block_Description"                                                            "Blocks %dMODIFIER_PROPERTY_TOTAL_CONSTANT_BLOCK% damage from each attack."
        "DOTA_Tooltip_ability_pudge_flesh_heap_lua_ability_note"                                                                  "Can be cast on <font color='#B694FF'>creeps.</font><br>Strength bonus from <font color='#B694FF'>Flesh Heap</font> will be lost when replacing this ability.<br>15% chance enemy attacking you can be stunned for 0.75 seconds. Effect does not work on creeps and is disabled during break."
        "DOTA_Tooltip_ability_pudge_meat_hook_shard_description"                                                                 ""
        // pudge_rot scepter desc — vanilla uses %bonus_rot_radius% / %bonus_rot_damage%
        // which engine breaks at ability level 0 (shows -50 / NaN). Hardcode the deltas.
        "DOTA_Tooltip_ability_pudge_rot_scepter_description"                                                                     "Increases the radius of Rot by 200 and its damage by 90. Also reduces health regeneration of victims by %scepter_rot_regen_reduction_pct%%%."
        // Same %bonus_X% bug — hardcoded (dynamic ref didn't work due to engine quirks)
        "DOTA_Tooltip_ability_nyx_assassin_vendetta_shard_description"                                                           "Reduces cooldown by 10 sec. For the first %free_pathing_duration% sec. of Vendetta, Nyx Assassin gains movement speed bonus and can pass through obstacles."
        "DOTA_Tooltip_ability_mars_arena_of_blood_scepter_description"                                                           "Reduces cooldown by 10 sec and increases duration. If an enemy dies inside the arena, Mars and all allies within restore %arena_kill_buff_heal_pct%%% of max HP and mana and get +%arena_kill_buff_damage_pct%%% attack damage for %arena_kill_buff_duration% sec. Stacks."
        // blade_fury has neither scepter nor shard upgrade in current patch (scepter→swift_slash, shard→healing_ward).
        // Vanilla descriptions are legacy artifacts — suppress.
        "DOTA_Tooltip_ability_juggernaut_blade_fury_shard_description"                                                           ""
        "DOTA_Tooltip_ability_juggernaut_blade_fury_scepter_description"                                                         ""
