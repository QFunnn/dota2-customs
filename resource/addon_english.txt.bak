      "VOTES_LIST_INIT_SMOKES"                                                                                                            "Starting smoke count"
      "VOTES_LIST_INIT_LIFES"                                                                                                             "Starting lives count"
      "VOTES_LIST_SSS_COUNT_FIRST"                                                                                                        "SSS abilities count in first choice"
      "VOTES_LIST_FIRST_ABILITY_IS_GENERAL"                                                                                               "General first choice"
      "VOTES_LIST_FIRST_ABILITY_IS_GENERAL_0"                                                                                             "No"
      "VOTES_LIST_FIRST_ABILITY_IS_GENERAL_1"                                                                                             "Yes"
      "VOTES_LIST_HAS_SKILLS_SELECT"                                                                                                      "Hero skills"
      "VOTES_LIST_HAS_SKILLS_SELECT_0"                                                                                                    "No"
      "VOTES_LIST_HAS_SKILLS_SELECT_1"                                                                                                    "Yes"
      "VOTES_LIST_CREEP_BONUS_ARMOR"                                                                                                      "Armor for late rounds"
      "VOTES_LIST_CREEP_BONUS_MAGIC_RESISTANCE"                                                                                           "Magic resist for late rounds"
      "VOTES_LIST_ROUND_WHEN_LOSE_AEGIS"                                                                                                  "Starting round for losing lives"
