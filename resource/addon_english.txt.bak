      //=================================================================================================================
      // Slark
      //=================================================================================================================
        "DOTA_Tooltip_ability_slark_shadow_dance_custom"                                                                          "Shadow Dance"
        "DOTA_Tooltip_ability_slark_shadow_dance_custom_Description"                                                              "Hides hero in shadow cloud, making him invisible. This invisibility is not revealed by anything; attacks, item use and ability casting also don't remove invisibility. Passively increases movement speed and health regeneration when hero is not seen by enemies."
        "DOTA_Tooltip_ability_slark_shadow_dance_custom_Lore"                                                                     "Unknown thirteenth is very slippery enemy."
        "DOTA_Tooltip_ability_slark_shadow_dance_custom_Note0"                                                                    "If taking damage from neutral creature, bonus speed and regeneration disappear for %neutral_disable% sec."
        "DOTA_Tooltip_ability_slark_shadow_dance_custom_Note1"                                                                    "Bonus speed and regeneration turn on and off with %activation_delay% sec. delay."
        "DOTA_Tooltip_ability_slark_shadow_dance_custom_duration"                                                                 "DURATION:"
        "DOTA_Tooltip_ability_slark_shadow_dance_custom_bonus_movement_speed"                                                     "%BONUS MOVEMENT SPEED:"
        "DOTA_Tooltip_ability_slark_shadow_dance_custom_bonus_regen"                                                              "HEALTH REGEN PER SECOND:"
        "DOTA_Tooltip_ability_slark_depth_shroud_custom"                                                                          "Depth Shroud"
        "DOTA_Tooltip_ability_slark_depth_shroud_custom_Description"                                                              "Creates cloud in specified area that hides allies and applies Shadow Dance ability effect on them. Cast range: %abilitycastrange%. Cooldown: %abilitycooldown% sec."
        "DOTA_Tooltip_ability_slark_depth_shroud_custom_duration"                                                                 "DURATION:"
        "DOTA_Tooltip_ability_slark_depth_shroud_custom_radius"                                                                   "RADIUS:"
        "DOTA_Tooltip_modifier_slark_shadow_dance_custom_passive"                                                                 "Shadow Dance Regeneration"
        "DOTA_Tooltip_modifier_slark_shadow_dance_custom_passive_Description"                                                     "Moves %dMODIFIER_PROPERTY_MOVESPEED_BONUS_PERCENTAGE%%% faster and restores %dMODIFIER_PROPERTY_HEALTH_REGEN_PERCENTAGE%%% of maximum health per second."
        "DOTA_Tooltip_modifier_slark_shadow_dance_custom"                                                                         "Shadow Dance"
        "DOTA_Tooltip_modifier_slark_shadow_dance_custom_Description"                                                             "Invisible in smoke cloud."
        "DOTA_Tooltip_modifier_slark_shadow_dance_custom_shard"                                                                   "Depth Shroud"
        "DOTA_Tooltip_modifier_slark_shadow_dance_custom_shard_Description"                                                       "Creature is hidden in Depth Shroud ability cloud."
        "DOTA_Tooltip_ability_slark_shadow_dance_ability_note"                                                                    ""
        "DOTA_Tooltip_ability_slark_essence_shift_lua_ability_note"                                                               "Also steals agility from creeps."
        "DOTA_Tooltip_ability_slark_essence_shift_lua"                                                                            "Essence Shift"
        "DOTA_Tooltip_ability_slark_essence_shift_lua_Description"                                                                "Hero exhausts enemies, stealing their attributes that turn into bonus agility for ability owner. If hero kills enemy, he permanently steals 1 agility."
        "DOTA_Tooltip_ability_slark_essence_shift_lua_Lore"                                                                       "With each strike, hero learns enemy's weak spots better and better."
        "DOTA_Tooltip_ability_slark_essence_shift_lua_Note0"                                                                      "Attributes cannot fall below 1."
        "DOTA_Tooltip_ability_slark_essence_shift_lua_Note1"                                                                      "Temporarily stolen enemy attributes return to them if hero dies."
        "DOTA_Tooltip_ability_slark_essence_shift_lua_Note2"                                                                      "To get permanent agility bonus from kill, Slark doesn't necessarily need to kill enemy, they can die from other circumstances while under Essence Shift effect."
        "DOTA_Tooltip_ability_slark_essence_shift_lua_agi_gain"                                                                   "AGILITY BONUS:"
        "DOTA_Tooltip_ability_slark_essence_shift_lua_stat_loss"                                                                  "TOTAL ATTRIBUTE LOSS:"
        "DOTA_Tooltip_ability_slark_essence_shift_lua_duration"                                                                   "DURATION:"
        "DOTA_Tooltip_modifier_slark_essence_shift_lua_agi"                                                                       "Essence Shift"
        "DOTA_Tooltip_modifier_slark_essence_shift_lua_agi_Description"                                                           "Gains %dMODIFIER_PROPERTY_STATS_AGILITY_BONUS% agility."
        "DOTA_Tooltip_modifier_slark_essence_shift_lua_agi_debuff"                                                                "Essence Shift"
        "DOTA_Tooltip_modifier_slark_essence_shift_lua_agi_debuff_Description"                                                    "Loses %dMODIFIER_PROPERTY_TOOLTIP% of each attribute."
        "DOTA_Tooltip_modifier_slark_essence_shift_lua_agi_permenant"                                                             "Essence Shift"
        "DOTA_Tooltip_modifier_slark_essence_shift_lua_agi_permenant_Description"                                                 "Gains %dMODIFIER_PROPERTY_STATS_AGILITY_BONUS% agility permanently."
        "DOTA_Tooltip_ability_slark_dark_pact_ability_note"                                                                       "Passively triggers when taking 500 damage with 7 sec. cooldown."
      //=================================================================================================================
      // Sniper
      //=================================================================================================================
        "DOTA_Tooltip_ability_sniper_take_aim_ability_note"                                                                       ""
        "DOTA_Tooltip_ability_sniper_assassinate_shard_description"                                                               ""
        "DOTA_Tooltip_ability_sniper_take_aim_custom"                                                                             "Take Aim"
        "DOTA_Tooltip_ability_sniper_take_aim_custom_Description"                                                                 "Increases hero's attack range. Casting for 4 seconds increases Headshot ability proc chance to %headshot_chance%%%, but slows owner's movement by %slow%%%.\n<h1>HeadShot</h1> Hero shoots more accurately, so each his attack can deal bonus damage, knockback victim and briefly slow their movement and attack by %slow%%%.<br><br>Chance: %proc_chance%%%<br>Knockback distance: %knockback_distance%<br>Damage: %damage%"
        "DOTA_Tooltip_ability_sniper_take_aim_custom_Lore"                                                                        "Kardel always tries to keep as far from danger as possible, while not forgetting his task: shoot accurately at target."
        "DOTA_Tooltip_ability_sniper_take_aim_custom_bonus_attack_range"                                                          "BONUS ATTACK RANGE:"
        "DOTA_Tooltip_ability_sniper_take_aim_custom_bonus_attack_range_active"                                                   "BONUS ATTACK RANGE WHEN ACTIVE:"
        "DOTA_Tooltip_ability_sniper_assassinate_custom"                                                                          "Assassinate"
        "DOTA_Tooltip_ability_sniper_assassinate_custom_Description"                                                              "Hero aims at enemy creature from huge distance and after short delay makes devastating shot that stuns target for %scepter_stun_duration% sec."
        "DOTA_Tooltip_ability_sniper_assassinate_custom_scepter_description"                                                      "Ability deals 200%% attack damage"
        "DOTA_Tooltip_ability_sniper_assassinate_custom_Lore"                                                                     "To fulfill prophecy and return to hometown, Kardel must be sure that next shot will be as accurate as the one he made on distant day of his trial."
        "DOTA_Tooltip_ability_sniper_assassinate_custom_shard_description"                                                        ""
        "DOTA_Tooltip_ability_sniper_assassinate_custom_Note0"                                                                    "Scope icon visible only to allies."
        "DOTA_Tooltip_ability_sniper_assassinate_custom_Note1"                                                                    "This ability's projectile cannot be deflected by invisibility."
        "DOTA_Tooltip_ability_sniper_assassinate_custom_abilitycastrange"                                                         "CAST RANGE:"
        "DOTA_Tooltip_ability_sniper_assassinate_custom_abilitycastpoint"                                                         "PREPARATION TIME:"
        "DOTA_Tooltip_ability_sniper_assassinate_custom_ability_note"                                                             "Applied to all targets in area of effect."
        "DOTA_Tooltip_ability_sniper_assassinate_custom_damage"                                                                  "DAMAGE:"
      //=================================================================================================================
      // Templar Assassin
      //================================================================================================================= 
        "DOTA_Tooltip_ability_ability_templar_assassin_third_eye"                                                                 "Third Eye"
        "DOTA_Tooltip_ability_ability_templar_assassin_third_eye_Description"                                                     "Reveals invisibility of all enemies around self in %radius% radius."
        "DOTA_Tooltip_ability_templar_assassin_meld_ability_note"                                                                 "Passively increases attack range by 300"
      //=================================================================================================================
      // Terrorblade
      //=================================================================================================================
        "DOTA_Tooltip_ability_custom_terrorblade_metamorphosis"                                                                   "Metamorphosis"
        "DOTA_Tooltip_ability_custom_terrorblade_metamorphosis_Description"                                                       "Hero and all his illusions within %metamorph_aura_tooltip% radius transform into powerful demons fighting in ranged combat."
        "DOTA_Tooltip_ability_custom_terrorblade_metamorphosis_Lore"                                                              "Hush, hush. Rage boils up and takes control over demon, making him even more terrifying."
        "DOTA_Tooltip_ability_custom_terrorblade_metamorphosis_duration"                                                          "DURATION:"
        "DOTA_Tooltip_ability_custom_terrorblade_metamorphosis_transformation_time"                                               "TRANSFORMATION TIME:"
        "DOTA_Tooltip_ability_custom_terrorblade_metamorphosis_base_attack_time"                                                  "BASE ATTACK TIME:"
        "DOTA_Tooltip_ability_custom_terrorblade_metamorphosis_tooltip_attack_range"                                              "ATTACK RANGE:"
        "DOTA_Tooltip_ability_custom_terrorblade_metamorphosis_bonus_damage"                                                      "BONUS DAMAGE:"
        "DOTA_Tooltip_ability_custom_terrorblade_metamorphosis_metamorph_aura_tooltip"                                            "EFFECT RADIUS ON ILLUSIONS:"
        "DOTA_Tooltip_ability_custom_terrorblade_metamorphosis_scepter_description"                                               "Ability becomes toggle. When activated hero gains ability to pass through obstacles and changes attack type to ranged. Effect persists until toggled off."
        "DOTA_Tooltip_ability_custom_terrorblade_metamorphosis_Note0"                                                             "Cooldown of some items depends on which attack type hero had when using them."
        "DOTA_Tooltip_modifier_custom_terrorblade_metamorphosis"                                                                  "Metamorphosis"
        "DOTA_Tooltip_modifier_custom_terrorblade_metamorphosis_Description"                                                      "Powerful demonic form with ranged attack."
        "DOTA_Tooltip_ability_custom_terrorblade_metamorphosis_ability_note"                                                      ""
        "DOTA_Tooltip_ability_terrorblade_sunder_datadriven"                                                                      "Sunder"
        "DOTA_Tooltip_ability_terrorblade_sunder_datadriven_Description"                                                          "Swaps hero's and target's life forces. Some portion of health remains in place."
        "DOTA_Tooltip_ability_terrorblade_sunder_datadriven_hit_point_minimum_pct"                                                "MIN HEALTH AFTER SWAP:"
        "DOTA_Tooltip_ability_terrorblade_reflection_lua"                                                                         "Reflection"
        "DOTA_Tooltip_ability_terrorblade_reflection_lua_Description"                                                             "Terrorblade creates invulnerable dark doubles of all enemy heroes in specified area. Affected enemy heroes are slowed and attack their target.\nEnemy creeps are slowed and take physical damage based on their base damage. Damage intervals are based on creep's base attack time. Affects maximum %max_creep_affect% enemy creeps."
        "DOTA_Tooltip_ability_terrorblade_reflection_lua_Lore"                                                                    "In fractal prison Foulfell Terrorblade learned truth of this old tale: you are your own worst enemy. Now it's lesson he teaches others."
        "DOTA_Tooltip_ability_terrorblade_reflection_lua_illusion_duration"                                                       "REFLECTION DURATION:"
        "DOTA_Tooltip_ability_terrorblade_reflection_lua_illusion_outgoing_tooltip"                                               "%REFLECTION DAMAGE:"
        "DOTA_Tooltip_ability_terrorblade_reflection_lua_move_slow"                                                               "%MOVEMENT SLOW:"
        "DOTA_Tooltip_ability_terrorblade_reflection_lua_range"                                                                   "RADIUS:"
        "DOTA_Tooltip_ability_terrorblade_reflection_lua_Note0"                                                                   "Reflections are invulnerable, invincible illusions that will be destroyed if slow is removed."
        "DOTA_Tooltip_ability_terrorblade_reflection_lua_Note1"                                                                   "Reflections can only attack their source."
        "DOTA_Tooltip_ability_terrorblade_reflection_lua_ability_note"                                                            "Hero reflection illusion gains target's base damage + %hero_green_damage_pct%%% of its bonus damage.\nEnemy creeps are slowed and take physical damage based on their base damage + %hero_green_damage_pct%%% of their bonus damage. Damage intervals are based on creep's base attack time.\nAbility affects up to %max_creep_affect% targets total (heroes and creeps combined)."
        "DOTA_Tooltip_Ability_special_bonus_unique_cha_terrorblade"                                                               "+{s:bonus_bonus_range} attack range from Metamorphosis"
      //=================================================================================================================
