      "DOTA_Tooltip_modifier_item_gem_shard"                                                                                      "Gem Shard"
      "DOTA_Tooltip_modifier_item_gem_shard_Description"                                                                          "Grants owner and their allies ability to see invisible units and wards in %dMODIFIER_PROPERTY_TOOLTIP% radius"

      "DOTA_Tooltip_ability_item_gem_shard_2"                                                                                     "Gem Shard 2"
      "DOTA_Tooltip_ability_item_gem_shard_2_Description"                                                                         "<h1>Use: Consume</h1> Grants owner and their allies ability to see invisible units and wards in %radius% radius.\n<font color='#f00'>Available for activation only after purchasing Gem Shard.</font>"
      "DOTA_Tooltip_modifier_item_gem_shard_2"                                                                                    "Gem Shard 2"
