        "DOTA_Tooltip_ability_skeleton_king_vampiric_aura_custom_skeleton_damage_tooltip"                                         "SKELETON DAMAGE:"
        "DOTA_Tooltip_ability_skeleton_king_vampiric_aura_custom_skeleton_health_tooltip"                                         "SKELETON HEALTH:"
