        "DOTA_Tooltip_modifier_shredder_chakram_disarm_lua"                                                                       "Chakram Disarm"
        "DOTA_Tooltip_modifier_shredder_chakram_disarm_lua_Description"                                                           "You cannot attack while Chakram is in air."
