      "DOTA_Tooltip_ability_item_dagon_4_custom_bonus_agi"                                                                        "+$agi"

      "DOTA_Tooltip_Ability_item_dagon_5_custom"                                                                                  "Dagon"
      "DOTA_Tooltip_ability_item_dagon_5_custom_Description"                                                                      "<h1>Active: Energy Burst</h1> Releases a powerful energy burst, dealing magical damage to selected enemy unit.<br><br>Disables <b><font color='#53ea48'>passive</font></b> abilities of selected target for %duration% sec.<br><br>Damage: %damage%<br>Cast range: %abilitycastrange%<br>Mana cost: %mana_cost_tooltip%"
      "DOTA_Tooltip_ability_item_dagon_5_custom_Lore"                                                                             "A magic wand that grows stronger over time, granting owner magic at their fingertips."
      "DOTA_Tooltip_ability_item_dagon_5_custom_Note0"                                                                            "Instantly kills illusions."
      "DOTA_Tooltip_ability_item_dagon_5_custom_bonus_int"                                                                        "+$int"
      "DOTA_Tooltip_ability_item_dagon_5_custom_bonus_str"                                                                        "+$str"
      "DOTA_Tooltip_ability_item_dagon_5_custom_bonus_agi"                                                                        "+$agi"

      "DOTA_Tooltip_modifier_item_dagon_custom_break"                                                                             "Dagon"
      "DOTA_Tooltip_modifier_item_dagon_custom_break_Description"                                                                 "Passive abilities disabled"

      "DOTA_Tooltip_ability_item_book_of_strength"                                                                                "Book of Strength"
      "DOTA_Tooltip_ability_item_book_of_strength_Description"                                                                    "Permanently increases Strength by 3"
      "DOTA_Tooltip_ability_item_book_of_agility"                                                                                 "Book of Agility"
      "DOTA_Tooltip_ability_item_book_of_agility_Description"                                                                     "Permanently increases Agility by 3"
      "DOTA_Tooltip_ability_item_book_of_intelligence"                                                                            "Book of Intelligence"
      "DOTA_Tooltip_ability_item_book_of_intelligence_Description"                                                                "Permanently increases Intelligence by 3"

      "DOTA_Tooltip_modifier_book_of_strength"                                                                                    "Book of Strength"
      "DOTA_Tooltip_modifier_book_of_strength_Description"                                                                        "Strength gained from using books"
      "DOTA_Tooltip_modifier_book_of_agility"                                                                                     "Book of Agility"
      "DOTA_Tooltip_modifier_book_of_agility_Description"                                                                         "Agility gained from using books"
      "DOTA_Tooltip_modifier_book_of_intelligence"                                                                                "Book of Intelligence"
      "DOTA_Tooltip_modifier_book_of_intelligence_Description"                                                                    "Intelligence gained from using books"

      "DOTA_Tooltip_ability_item_spell_book_empty_lua"                                                                            "Empty Spell Scroll"
      "DOTA_Tooltip_ability_item_spell_book_empty_lua_Description"                                                                "<h1>Consume: Record</h1>Record one of your abilities of choice in the scroll. It will save information about spell level and cooldown."
      "save_spell_book"                                                                                                           "Save ability in spell scroll<b><font color='#FFE815'>( 150 gold )</font></b>"
      "DOTA_Tooltip_ability_item_relearn_book_lua"                                                                                "Retraining Book"
      "DOTA_Tooltip_ability_item_relearn_book_lua_Description"                                                                    "<h1>Consume: Retraining</h1>Select one of your abilities and replace it with another."

      "DOTA_Tooltip_ability_item_relearn_book_return"                                                                             "Supreme Retraining Book"
      "DOTA_Tooltip_ability_item_relearn_book_return_Description"                                                                 "<h1>Consume: Retraining</h1>Select one of your abilities and replace it with another.<br><br>The list of new abilities will definitely include the one that was selected for replacement."

      "DOTA_Tooltip_ability_item_relearn_book_sss"                                                                                "SSS Retraining Book"
      "DOTA_Tooltip_ability_item_relearn_book_sss_Description"                                                                    "<h1>Consume: Retraining</h1>Select one of your abilities and replace it with another.<br><br>The new abilities list will definitely include {count} SSS {sss_word}.<br><br>Item can be purchased at the following rounds: {rounds} — one charge appears in shop."
      "SSS_ABILITY_FORM_ONE"                                                                                                     "ability"
      "SSS_ABILITY_FORM_FEW"                                                                                                     "abilities"
      "SSS_ABILITY_FORM_MANY"                                                                                                    "abilities"

      "DOTA_Tooltip_ability_item_swap_essence"                                                                                    "Primal Essence"
      "DOTA_Tooltip_ability_item_swap_essence_Description"                                                                        "<h1>Use: Primal Swap</h1>2v6 mode only<br>Exchanges one of your abilities with an ally."
        
       "DOTA_Tooltip_ability_item_bloodstone_2"                                                                                   "Bloodstone 2"
      "DOTA_Tooltip_ability_item_bloodstone_2_Description"                                                                        "<h1>Active: Bloodpact</h1> Converts %mana_cost_percentage%%% of maximum mana pool into health over %restore_duration% sec.<br><br>Dispel type: <b>normal</b> \n <h1>Passive: Mana Battery</h1>Each charge increases mana regeneration by %regen_per_charge% and spell damage by %amp_per_charge%%%. Initially item has %initial_charges_tooltip% charges. Gains %kill_charges% charge for each nearby kill.\n<font color='#f00'>Does not earn charges in Mass Arena</font> \n <font color='#f00'>Does not lose charges on death</font>"
      "DOTA_Tooltip_ability_item_bloodstone_2_Lore"                                                                               "The crimson of this stone is easy to notice even in heat of battle: it seemingly grants owner limitless vital and spiritual forces."
      "DOTA_Tooltip_ability_item_bloodstone_2_bonus_health_custom"                                                                "+$health"
      "DOTA_Tooltip_ability_item_bloodstone_2_bonus_mana_custom"                                                                  "+$mana"
      "DOTA_Tooltip_ability_item_bloodstone_2_bonus_intellect"                                                                    "+$int"
      "DOTA_Tooltip_ability_item_bloodstone_2_bonus_health_regen"                                                                 "+$hp_regen"
      "DOTA_Tooltip_ability_item_bloodstone_2_spell_amp"                                                                          "%+ spell damage"
      "DOTA_Tooltip_ability_item_bloodstone_2_hero_lifesteal"                                                                     "%+ spell lifesteal (from heroes)"
      "DOTA_Tooltip_ability_item_bloodstone_2_creep_lifesteal"                                                                    "%+ spell lifesteal (from creeps)"
      "DOTA_Tooltip_ability_item_bloodstone_2_mana_regen_multiplier"                                                              "%+ mana regeneration amplification"
      "DOTA_Tooltip_ability_item_bloodstone_2_spell_lifesteal_amp"                                                                "%+ spell lifesteal amplification"
      "DOTA_Tooltip_ability_item_bloodstone_2_bonus_aoe"                                                                          "+$aoe_bonus"
   
      "DOTA_Tooltip_ability_item_ranged_cleave"                                                                                   "Replica Rackatee"
      "DOTA_Tooltip_ability_item_ranged_cleave_Description"                                                                       "<h1>Passive: Scatterblast</h1>RANGED HEROES ONLY: deals %cleave_dmg%%% attack damage to enemies in %cleave_radius% radius around main target"
      "DOTA_Tooltip_ability_item_ranged_cleave_bonus_str"                                                                         "+$str"
      "DOTA_Tooltip_ability_item_ranged_cleave_bonus_agi"                                                                         "+$agi"
      "DOTA_Tooltip_ability_item_ranged_cleave_bonus_dmg"                                                                         "+$damage"
      "DOTA_Tooltip_ability_item_ranged_cleave_bonus_range"                                                                       "+$attack_range"
      "DOTA_Tooltip_ability_item_ranged_cleave_lore"                                                                              "A three-barrel, wide-bore gun made from blueprints of one of Beatrix Snapfire's weapons. Not as destructive, but groups shots nicely"
      
      "DOTA_Tooltip_ability_item_ranged_cleave_2"                                                                                 "Beadie's Boomstick"
      "DOTA_Tooltip_ability_item_ranged_cleave_2_Description"                                                                     "<h1>Passive: Greater Scatterblast</h1>RANGED HEROES ONLY: deals %cleave_dmg%%% attack damage to enemies in %cleave_radius% radius around main target. Increases attack range by %bonus_range%"
      "DOTA_Tooltip_ability_item_ranged_cleave_2_bonus_str"                                                                       "+$str"
      "DOTA_Tooltip_ability_item_ranged_cleave_2_bonus_agi"                                                                       "+$agi"
      "DOTA_Tooltip_ability_item_ranged_cleave_2_bonus_dmg"                                                                       "+$damage"
      "DOTA_Tooltip_ability_item_ranged_cleave_2_bonus_range"                                                                     "+$attack_range"
      "DOTA_Tooltip_ability_item_ranged_cleave_2_lore"                                                                            "Many wonder: how can a 4-foot-tall grandmother survive attack from ferocious Outland beasts? The answer is simple - Beatrix's monstrous three-barrel, more siege weapon than shotgun, which she calls 'boomstick'."

      "DOTA_Tooltip_ability_item_ranged_cleave_3"                                                                                 "Eternal Beadie's Boomstick"
      "DOTA_Tooltip_ability_item_ranged_cleave_3_Description"                                                                     "<h1>Passive: Eternal Beadie's Boomstick</h1>RANGED HEROES ONLY: Increases your damage to creeps by %bonus_damage_creeps_no_late%%% (by %bonus_damage_creeps_late%%% after wave 40) and attacks deal %cleave_dmg%%% damage in %cleave_radius% radius around main target.<br><br><font color='#f00'>Disabled by break</font>"
      "DOTA_Tooltip_ability_item_ranged_cleave_3_Note0"                                                                           ""
      "DOTA_Tooltip_ability_item_ranged_cleave_3_bonus_str"                                                                       "+$str"
      "DOTA_Tooltip_ability_item_ranged_cleave_3_bonus_agi"                                                                       "+$agi"
      "DOTA_Tooltip_ability_item_ranged_cleave_3_bonus_dmg"                                                                       "+$damage"
      "DOTA_Tooltip_ability_item_ranged_cleave_3_attack_speed"                                                                    "+$attack"
      "DOTA_Tooltip_ability_item_ranged_cleave_3_bonus_range"                                                                     "+$attack_range"
      "DOTA_Tooltip_ability_item_ranged_cleave_3_lore"                                                                            ""

      "DOTA_Tooltip_Ability_item_recipe_aeon_disk_lua"                                                                            "Recipe: Aeon Disk"
      "DOTA_Tooltip_Ability_item_aeon_disk_lua"                                                                                   "Aeon Disk"
      "DOTA_Tooltip_ability_item_aeon_disk_lua_Description"                                                                       "<h1>Passive: Combo Breaker</h1> If your health drops below %health_threshold_pct%% when taking damage, a strong dispel is applied to you, and you receive a buff for %buff_duration% seconds that grants +%status_resistance%%% status resistance and reduces damage taken and dealt to zero. Can trigger from creeps."
      "DOTA_Tooltip_ability_item_aeon_disk_lua_lore"                                                                              "A powerful artifact, long ago, as they say, stolen from the White Incubatory."
      "DOTA_Tooltip_ability_item_aeon_disk_lua_bonus_health"                                                                      "+$health"
      "DOTA_Tooltip_ability_item_aeon_disk_lua_bonus_mana"                                                                        "+$mana"

      "DOTA_Tooltip_modifier_item_aeon_disk_lua_buff"                                                                             "Combo Breaker"
      "DOTA_Tooltip_modifier_item_aeon_disk_lua_buff_Description"                                                                 "All damage taken and dealt reduced."

      "DOTA_Tooltip_Ability_item_desolator_2_custom"                                                                              "Stygian Desolator"
      "DOTA_Tooltip_Ability_item_desolator_2_custom_Description"                                                                  "<h1>Passive: Greater Corruption</h1>Each attack reduces target armor by %corruption_armor% for %corruption_duration% sec. Armor reduction works on buildings.\n\n<h1>Passive: Splash Strike</h1>Each attack also hits up to %arrow_count% random enemies within the owner's attack range.\n\n<h1>Stats:</h1>+%bonus_damage% attack damage"
      "DOTA_Tooltip_Ability_item_desolator_2_custom_Note0"                                                                        "Armor reduction works on buildings."
    // Bonus stat labels intentionally omitted — values inline in Description's «Stats:».
      "DOTA_Tooltip_Ability_item_desolator_2_custom_Lore"                                                                         "This weapon, so beloved by demons, became the ancestor of creation so beloved by mortals."

      "DOTA_Tooltip_Ability_item_ballista_Description"                                                                            "<h1>Passive: Knockback</h1>Each attack knocks the enemy back by %knockback_distance% and deals %bonus_damage% pure damage.\n\n<h1>Stats:</h1>+%attack_range_bonus% attack range (ranged only)"

      "DOTA_Tooltip_Ability_item_ogre_seal_totem_Description"                                                                     "<h1>Active: Ogre Seal Flop</h1>Leaps %leap_distance% in facing direction. On landing deals %flop_damage% damage and slows enemies by %slow%%% for %slow_duration% sec. within %radius%."

      "DOTA_Tooltip_Ability_item_crippling_crossbow_Description"                                                                  "<h1>Active: Crippling Bolt</h1>Fires a bolt at a target up to %AbilityCastRange% range, dealing %damage% magical damage. For %duration% sec. slows the target by %slow_pct%%% and reduces incoming heal by %heal_reduce%%%."

      "DOTA_Tooltip_Ability_item_magnifying_monocle_Description"                                                                  "<h1>Passive:</h1>After taking %damage_threshold% damage from an enemy attack or ability, the owner loses item bonuses for %damage_disable% sec.\n\n<h1>Stats:</h1>+%bonus_attack_range% attack range<br>+%bonus_cast_range% cast range"

      "DOTA_Tooltip_Ability_item_ceremonial_robe_Description"                                                                     "<h1>Passive:</h1>Reduces magic resistance and status resistance of enemies within %aura_radius%.\n\n<h1>Stats:</h1>-%magic_resistance%%% enemy magic resistance (aura)<br>-%status_resistance%%% enemy status resistance (aura)"

      "DOTA_Tooltip_Ability_item_mind_breaker_Description"                                                                        "<h1>Passive:</h1>Attacks deal %magic_damage% magical damage. The next ability cast by the target reduces its attack speed by %attack_speed% for %duration% sec. Cooldown %AbilityCooldown% sec."

      // ===== Tier 3 =====
      "DOTA_Tooltip_Ability_item_serrated_shiv_Description"                                                                       "<h1>Passive:</h1>%proc_chance%%% chance on attack to deal %hp_dmg% bonus pure damage. Attacks on Roshan deal %hp_dmg_rosh% bonus pure damage. Cooldown %AbilityCooldown% sec."

      "DOTA_Tooltip_Ability_item_nemesis_curse_Description"                                                                       "<h1>Passive:</h1>When the owner takes damage from an ability or attack, they are debuffed for %debuff_self% sec. Attacking the enemy who applied the debuff curses them for %debuff_enemy% sec., preventing them from being healed (%debuff_enemy_duration% sec. effect)."

      "DOTA_Tooltip_Ability_item_gale_guard_Description"                                                                          "<h1>Active: Gale Guard</h1>Grants a %barrier_amount%-damage barrier for %barrier_duration% sec. While active, reduces incoming damage by %barrier_pct%%% and grants +%slow_resist%%% slow resistance."

      "DOTA_Tooltip_Ability_item_gunpowder_gauntlets_Description"                                                                 "<h1>Passive:</h1>Once every %AbilityCooldown% sec. an attack deals +%bonus_damage% damage and splashes %splash_pct%%% of that to enemies within %splash_radius%."

      "DOTA_Tooltip_Ability_item_whisper_of_the_dread_Description"                                                                "<h1>Passive:</h1>Enemies within owner's vision lose %vision_penalty% vision range.\n\n<h1>Stats:</h1>+%bonus_spell_damage%%% spell amp"

      // ===== Tier 2 =====
      "DOTA_Tooltip_Ability_item_essence_ring_Description"                                                                        "<h1>Active: Essence Aid</h1>Heals %health_gain% HP over %health_gain_duration% sec."

      "DOTA_Tooltip_Ability_item_iron_talon_Description"                                                                          "<h1>Active: Iron Talon</h1>Chops a tree or deals %creep_damage_pct%%% of current HP as pure damage to a creep (max range %AbilityCastRange%). Alternate cooldown on trees: %alternative_cooldown% sec."

      "DOTA_Tooltip_Ability_item_gossamer_cape_Description"                                                                       "<h1>Passive:</h1>After taking damage from a spell, the owner gains partial invisibility for %AbilityCooldown% sec.\n\n<h1>Stats:</h1>+%movement_speed% movement speed"

      "DOTA_Tooltip_Ability_item_searing_signet_Description"                                                                      "<h1>Passive:</h1>After the owner deals %damage_threshold% damage in a single attack, the target burns for %burn_duration% sec., taking %burn_damage% magical damage total. Triggers only within %max_range%."

      "DOTA_Tooltip_Ability_item_pogo_stick_Description"                                                                          "<h1>Active: Pogo Hop</h1>Leaps %leap_distance% in facing direction. Cooldown %AbilityCooldown% sec."

      // ===== Tier 1 =====
      "DOTA_Tooltip_Ability_item_trusty_shovel_Description"                                                                       "<h1>Active: Dig</h1>Channels for %AbilityChannelTime% sec. — %chance_bounty_rune%%% chance to dig up a bounty rune, %chance_other_item%%% chance to dig up a consumable. Otherwise, summons a kobold for %kobold_duration% sec."

      "DOTA_Tooltip_Ability_item_occult_bracelet_Description"                                                                     "<h1>Passive:</h1>When the owner applies a debuff to an enemy or receives a debuff, gains %mana_regen% mana regen/sec for %stack_duration% sec. Stacks up to %stack_limit% times."

      "DOTA_Tooltip_Ability_item_unstable_wand_Description"                                                                       "<h1>Active: Unstable Surge</h1>For %duration% sec. the owner gains +%active_movespeed_pct%%% movement speed. Cooldown %AbilityCooldown% sec."

      "DOTA_Tooltip_Ability_item_spark_of_courage_Description"                                                                    "<h1>Passive:</h1>While owner's HP is above %health_pct%%%, gains +%damage% attack damage and +%armor% armor."

      "DOTA_Tooltip_Ability_item_rippers_lash_Description"                                                                        "<h1>Active: Rippers Lash</h1>Creates a thorn carpet within %thorn_area% radius for %duration% sec. Enemy heroes inside take +%bonus_damage_hero% physical attack damage, creeps take +%bonus_damage_creep%."

      "DOTA_Tooltip_Ability_item_orb_of_destruction_Description"                                                                  "<h1>Passive:</h1>Each attack reduces target armor by %armor_reduction% and slows it by %slow_melee% (melee) or %slow_range% (ranged) for %duration% sec."

      "DOTA_Tooltip_Ability_item_essence_of_speed"                                                                                "Essence of Speed"
      "DOTA_Tooltip_ability_item_essence_of_speed_Description"                                                                    "<h1>Active: Consume the Essence</h1>Permanently increases your movement speed by %speed_bonus%. Can only be used once."

      "DOTA_Tooltip_modifier_item_essence_of_speed"                                                                               "Essence of Speed"
      "DOTA_Tooltip_modifier_item_essence_of_speed_Description"                                                                   "Movement speed permanently increased by <b><font color='#53ea48'>%dMODIFIER_PROPERTY_MOVESPEED_BONUS_CONSTANT%</font></b>"

      "essence_speed"                                                                                                             "You have already used this item"

      "DOTA_Tooltip_Ability_item_urn_of_shadows_custom"                                                                           "Urn of Shadows"
      "DOTA_Tooltip_ability_item_urn_of_shadows_custom_Description"                                                               "<h1>Active: Soul Release</h1>Effect depends on selected target: either increases ally's health regeneration by %soul_heal_amount%, or deals %soul_damage_amount% damage per second to enemy. <br><br>Cast range: %abilitycastrange%"
      "DOTA_Tooltip_ability_item_urn_of_shadows_custom_Note0"                                                                     ""
      "DOTA_Tooltip_ability_item_urn_of_shadows_custom_Note1"                                                                     "If applied to enemy already affected by this item, effect duration refreshes."
      "DOTA_Tooltip_ability_item_urn_of_shadows_custom_Lore"                                                                      "Contains ashes of mighty demons."
      "DOTA_Tooltip_ability_item_urn_of_shadows_custom_bonus_health"                                                              "+$health"
      "DOTA_Tooltip_ability_item_urn_of_shadows_custom_mana_regen"                                                                "+$mana_regen"
      "DOTA_Tooltip_ability_item_urn_of_shadows_custom_bonus_armor"                                                               "+$armor"
      "DOTA_Tooltip_ability_item_urn_of_shadows_custom_bonus_all_stats"                                                           "+$all"

      "DOTA_Tooltip_Ability_item_spirit_vessel_custom"                                                                            "Spirit Vessel"
      "DOTA_Tooltip_ability_item_spirit_vessel_custom_Description"                                                                "<h1>Active: Soul Release</h1>Effect depends on selected target. If applied to enemy, they will lose %enemy_hp_drain%%% of their current health pool, and receive %hp_regen_reduction_enemy%%% less health from any healing, regeneration and lifesteal. Additionally, ability deals %soul_damage_amount% damage per second. <br><br>If applied to ally, increases their health regeneration by %soul_heal_amount% per second. <br><br>Lasts %duration% sec.<br><br>Cast range: %abilitycastrange%"
      "DOTA_Tooltip_ability_item_spirit_vessel_custom_lore"                                                                       "Created by a god who wished to capture souls of others."
      "DOTA_Tooltip_ability_item_spirit_vessel_custom_bonus_health"                                                               "+$health"
      "DOTA_Tooltip_ability_item_spirit_vessel_custom_bonus_mana_regen"                                                           "+$mana_regen"
      "DOTA_Tooltip_ability_item_spirit_vessel_custom_bonus_all_stats"                                                            "+$all"
      "DOTA_Tooltip_ability_item_spirit_vessel_custom_bonus_armor"                                                                "+$armor"
      "DOTA_Tooltip_ability_item_spirit_vessel_custom_mana_regen"                                                                 "+$mana_regen"

      "DOTA_Tooltip_Ability_item_mekansm_custom"                                                                                  "Mekansm"
      "DOTA_Tooltip_ability_item_mekansm_custom_Description"                                                                      "<h1>Active: Restore</h1> Restores %heal_amount%%% of maximum health to all allies in %heal_radius% radius.\n\n<h1>Passive: Mekansm Aura</h1> Increases health regeneration by %aura_health_regen% for all allies in %aura_radius% radius."
      "DOTA_Tooltip_ability_item_mekansm_custom_Lore"                                                                             "A shining gem assembled from parts that miraculously perfectly complement each other."
      "DOTA_Tooltip_ability_item_mekansm_custom_Note0"                                                                            "Restore (and Mend of Guardian Greaves) works on same unit no more than once per spell cooldown."
      "DOTA_Tooltip_ability_item_mekansm_custom_Note1"                                                                            "Multiple Mekansm Aura effects do not stack."
      "DOTA_Tooltip_ability_item_mekansm_custom_bonus_armor"                                                                      "+$armor"

      "DOTA_Tooltip_Ability_item_guardian_greaves_custom"                                                                         "Guardian Greaves"
      "DOTA_Tooltip_ability_item_guardian_greaves_custom_Description"                                                             "<h1>Active: Mend</h1>Restores %replenish_health%%% of max health and %replenish_mana%%% of max mana to all nearby allies, and removes most negative effects from owner.<br><br>Radius: %replenish_radius%<br>Dispel type: <span class=\"GameplayValues GameplayVariable\">normal</span>\n\n<h1>Passive: Guardian Aura</h1> Increases allies' health regeneration by %aura_health_regen% and their armor by %aura_armor%. Allied heroes with health below %aura_bonus_threshold%%% receive %aura_health_regen_bonus% health regeneration per second and %aura_armor_bonus% armor from aura.<br><br>Radius: %aura_radius%\nMovement speed bonuses from multiple pairs of boots do not stack."
      "DOTA_Tooltip_ability_item_guardian_greaves_custom_bonus_movement"                                                          "+$move_speed"
      "DOTA_Tooltip_ability_item_guardian_greaves_custom_bonus_mana"                                                              "+$mana"
      "DOTA_Tooltip_ability_item_guardian_greaves_custom_bonus_armor"                                                             "+$armor"
      "DOTA_Tooltip_ability_item_guardian_greaves_custom_Lore"                                                                    "One of many sacred tools created in glory of the Omniscience."
      "DOTA_Tooltip_ability_item_guardian_greaves_custom_Note0"                                                                   "Aura strengthens only on heroes."
      "DOTA_Tooltip_ability_item_guardian_greaves_custom_Note1"                                                                   "Mend (and Restore of Mekansm) works on same unit no more than once per spell cooldown."
      
      "DOTA_Tooltip_modifier_item_guardian_greaves_custom_buff"                                                                   "Guardian Aura"
      "DOTA_Tooltip_modifier_item_guardian_greaves_custom_buff_Description"                                                       "Health regeneration increased by %fMODIFIER_PROPERTY_HEALTH_REGEN_CONSTANT%. Armor increased by %dMODIFIER_PROPERTY_PHYSICAL_ARMOR_BONUS%."

      "DOTA_Tooltip_Ability_item_disperser_custom"                                                                                "Disperser"
      "DOTA_Tooltip_ability_item_disperser_custom_Description"                                                                    "<h1>Active: Suppress</h1> If used on enemy, slows them for %enemy_effect_duration% sec. If used on ally, applies normal dispel to them and increases their movement speed by %phase_movement_speed%%%. This ally cannot be slowed for %ally_effect_duration% sec.<br><br>Both slow and haste start at 100%%, gradually decreasing to zero over duration.<br><br>Cast range: %abilitycastrange%\n\n<h1>Passive: Manabreak</h1> Each attack burns %feedback_mana_burn% mana from enemies in <font color='#22c20a'>radius</font> %burn_radius% and deals %damage_per_burn% physical damage per burned mana point.<br><br>Illusions of melee heroes burn %feedback_mana_burn_illusion_melee% mana per attack, ranged — %feedback_mana_burn_illusion_ranged%.<br><br><font color='#f00'>Disabled by break</font>"
      "DOTA_Tooltip_ability_item_disperser_custom_bonus_agility"                                                                  "+$agi"
      "DOTA_Tooltip_ability_item_disperser_custom_bonus_intellect"                                                                "+$int"
      "DOTA_Tooltip_ability_item_disperser_custom_bonus_damage"                                                                   "+$damage"

      "DOTA_Tooltip_Ability_item_magilys_custom"                                                                                  "Magilys"
      "DOTA_Tooltip_ability_item_magilys_custom_Description"                                                                      "<h1>Passive: Magilys</h1> Magical damage has %chance%%% chance to deal %critical_damage%%% critical damage. Cooldown %cooldown_crit% sec. If target is creep and has Magic gleipnir effect, chance increases by %bonus_crit_creep%%% and item does not go on cooldown"
      "DOTA_Tooltip_ability_item_magilys_custom_bonus_intellect"                                                                  "+$int"

      "DOTA_Tooltip_Ability_item_gleipnir_magic_custom"                                                                           "Magic gleipnir"
      "DOTA_Tooltip_ability_item_gleipnir_magic_custom_Description"                                                               "<h1>Active: Magic gleipnir</h1> Applies root to all enemies in %radius% radius and increases magical damage dealt to them by %spell_amplify%%%. Root duration %duration% sec, debuff duration %debuff_duration% sec.\n\n<h1>Passive: Spell Lifesteal</h1> Grants %spell_lifesteal%%% spell lifesteal.\n\n<h1>Passive: Kryptonite</h1> Any ability use applies Phylactery effect to enemies in %radius% radius and deals additional %bonus_spell_damage% damage\n<h1>Passive: Magilys</h1> Magical damage has %chance%%% chance to deal %critical_damage%%% critical damage. Cooldown %cooldown_crit% sec. If target is creep and has Magic gleipnir effect, chance increases by %bonus_crit_creep%%% and item does not go on cooldown"
      "DOTA_Tooltip_ability_item_gleipnir_magic_custom_bonus_strength"                                                            "+$str"
      "DOTA_Tooltip_ability_item_gleipnir_magic_custom_bonus_agility"                                                             "+$agi"
      "DOTA_Tooltip_ability_item_gleipnir_magic_custom_bonus_intellect"                                                           "+$int"
      "DOTA_Tooltip_ability_item_gleipnir_magic_custom_spell_lifesteal"                                                           "%+$spell_lifesteal"

      "DOTA_Tooltip_modifier_item_gleipnir_magic_custom_debuff"                                                                   "Magic gleipnir"
      "DOTA_Tooltip_modifier_item_gleipnir_magic_custom_debuff_Description"                                                       "Incoming magical damage increased by 25%% and cannot move"

      "DOTA_Tooltip_modifier_item_gleipnir_magic_custom_debuff_rooted"                                                            "Magic gleipnir"
      "DOTA_Tooltip_modifier_item_gleipnir_magic_custom_debuff_rooted_Description"                                                "Cannot move"
      "DOTA_Tooltip_ability_item_book_of_shadows_custom"                                                                         "Book of Shadows"
      "DOTA_Tooltip_Ability_item_book_of_shadows_custom_Description"                                                             "<h1>Active: Shadows</h1>Can be cast on self, an ally, or an enemy. For %duration% sec. the target cannot be targeted, and cannot cast abilities, use items, or attack. Dispels effects from the target.\n\nDispel Type: <span class=\"GameplayValues GameplayVariable\">Basic Dispel</span>"
      "DOTA_Tooltip_ability_item_book_of_shadows_custom_Lore"                                                                    "An impossible tome filled with unreadable tales born from incomprehensible thoughts."
      "DOTA_Tooltip_ability_item_book_of_shadows_custom_Note0"                                                                   "This spell cannot be blocked or reflected."
      "DOTA_Tooltip_modifier_item_book_of_shadows_custom"                                                                        "Book of Shadows"
      "DOTA_Tooltip_modifier_item_book_of_shadows_custom_Description"                                                            "This unit cannot be targeted, and is silenced, disarmed, and muted."
      "DOTA_Tooltip_ability_item_book_of_shadows_custom_ability_note"                                                            ""
      "DOTA_Tooltip_Ability_item_trident_custom"                                                                                "Trident"
      "DOTA_Tooltip_Ability_item_trident_custom_Description"                                                                    "<h1>Passive:</h1>Each attack deals an extra %bonus_magical_attack% magical damage.\n\n<h1>Stats:</h1>+%bonus_strength% strength<br>+%bonus_agility% agility<br>+%bonus_intellect% intelligence<br>+%bonus_attack_speed% attack speed<br>+%bonus_movement_speed_pct%%% movement speed<br>+%bonus_status_resistance%%% status resistance<br>+%bonus_health_amp_pct%%% HP regen amp<br>+%bonus_spell_amp_pct%%% spell amp<br>+%bonus_mana_regen_amp_pct%%% mana regen amp"
    // Bonus stat labels intentionally omitted — values inline in Description's «Stats:».
      "DOTA_Tooltip_Ability_item_unwavering_condition_Description"                                                               "<h1>Passive:</h1>Owner's maximum health becomes %max_health% and can no longer be modified by other effects or attributes.\n\n<h1>Stats:</h1>+%magic_resist%%% magic resistance"

      "DOTA_Tooltip_Ability_item_mirror_shield_Description"                                                                     "<h1>Passive: Reflect</h1>%reflect_chance%%% chance to block and reflect the next enemy single-target spell. Cooldown %block_cooldown% sec."

      "DOTA_Tooltip_Ability_item_fallen_sky_Description"                                                                        "<h1>Active: Fallen Sky</h1>Jump to target point. On impact deals %impact_damage_units% damage in a %impact_radius% radius and stuns for %stun_duration% sec. Creates a burn zone for %burn_duration% sec. dealing %burn_dps_units% magical damage per second to enemies."

      "DOTA_Tooltip_Ability_item_force_field_Description"                                                                       "<h1>Active: Aegis Field</h1>Reflects %active_reflection_pct%%% of damage dealt to allies within %bonus_aoe_radius% (including owner).\n\n<h1>Passive:</h1>Grants armor and magic resistance aura to allies within %bonus_aoe_radius%.\n\n<h1>Stats:</h1>+%bonus_aoe_armor% armor (aura)<br>+%bonus_aoe_mres%%% magic resistance (aura)"
      "DOTA_Tooltip_ability_techies_spoons_stash_custom"                                                                         "Spoon's Stash"
      "DOTA_Tooltip_ability_techies_spoons_stash_custom_Description"                                                             "The hero has 2 additional active slots by replacing backpack slots. Neutral items cannot be placed in the additional slots."
     
