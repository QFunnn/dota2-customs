        "DOTA_Tooltip_ability_shredder_chakram_lua_return_Description"                                                            "Returns saw from Chakram ability to hero."
        "DOTA_Tooltip_ability_shredder_chakram_2_lua"                                                                             "Second Chakram"
        "DOTA_Tooltip_ability_shredder_chakram_2_lua_Description"                                                                 "Launches spare saw to specified location that spins, deals damage to enemies and slows their movement. Slow increases for every 5%% of lost health. Saw deals pure damage and cuts all trees in its path. While ability is active, its owner cannot attack and gradually loses mana."
        "DOTA_Tooltip_ability_shredder_chakram_2_lua_Lore"                                                                        "Whir-whir-whir-whir-whir-whir-whir-whir!"
        "DOTA_Tooltip_ability_shredder_chakram_2_lua_Note0"                                                                       "Saw will return to owner if he runs out of mana or if he moves away more than %break_distance%."
        "DOTA_Tooltip_ability_shredder_chakram_2_lua_Note1"                                                                       "Slow from two saws does not stack."
        "DOTA_Tooltip_ability_shredder_chakram_2_lua_radius"                                                                      "RADIUS:"
        "DOTA_Tooltip_ability_shredder_chakram_2_lua_pass_damage"                                                                 "INSTANT DAMAGE:"
