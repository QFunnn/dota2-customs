      //=================================================================================================================
        "DOTA_Tooltip_ability_gyrocopter_flak_cannon_lua"                                                                         "Flak Cannon"
        "DOTA_Tooltip_ability_gyrocopter_flak_cannon_lua_Description"                                                             "Several next hero's attacks are accompanied by volleys at all enemies in area around him. Attack effects (e.g. critical damage) work only on main target. Unused volleys disappear after %abilityduration% sec."
