        "DOTA_Tooltip_ability_skeleton_king_vampiric_spirit"                                                                    "Innate Ability"
        "DOTA_Tooltip_ability_skeleton_king_vampiric_spirit_Description"                                                        "Innate ability is temporarily disabled. It is being reworked and will be added soon."
        "DOTA_Tooltip_ability_skeleton_king_reincarnation_ability_note"                                                           "<font color='#F00'>Ability is disabled 5 seconds before main duel time ends.</font>"
        "DOTA_Tooltip_Ability_skeleton_king_vampiric_aura_custom"                                                                 "Vampiric Spirit"
        "DOTA_Tooltip_ability_skeleton_king_vampiric_aura_custom_Description"                                                     "Hero restores health based on damage dealt by attacks. Ability can be cast to summon skeletons. Dead skeletons resurrect once."
        "DOTA_Tooltip_ability_skeleton_king_vampiric_aura_custom_min_skeleton_spawn"                                              "SKELETON COUNT:"
