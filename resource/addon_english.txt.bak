        "DOTA_Tooltip_ability_phantom_assassin_blur_custom"                                                                       "Blur"
        "DOTA_Tooltip_ability_phantom_assassin_blur_custom_Description"                                                           "Hero focuses on self, allowing to dodge attacks. Casting ability blurs owner's outline, making him invisible if there are no enemy heroes, towers or outposts nearby.\nStacks with other evasion sources by diminishing returns law."
        "DOTA_Tooltip_ability_phantom_assassin_blur_custom_Lore"                                                                  "Meditation allows Veiled Sisters to stay ahead of opponents in battle."
        "DOTA_Tooltip_ability_phantom_assassin_blur_custom_bonus_evasion"                                                         "%EVASION:"
        "DOTA_Tooltip_ability_phantom_assassin_blur_custom_radius"                                                                "INVISIBILITY RADIUS:"
        "DOTA_Tooltip_ability_phantom_assassin_blur_custom_fade_duration"                                                         "DELAY BEFORE APPEARING:"
        "DOTA_Tooltip_ability_phantom_assassin_blur_custom_duration"                                                              "DURATION:"
        "DOTA_Tooltip_ability_phantom_assassin_blur_custom_ability_note"                                                          "Ability increases evasion and grants full invisibility"
        "DOTA_Tooltip_modifier_phantom_assassin_blur_custom_active"                                                               "Blur"
        "DOTA_Tooltip_modifier_phantom_assassin_blur_custom_active_Description"                                                   "Blurs outline, disappearing from enemy sight."
