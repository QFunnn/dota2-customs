      "DOTA_Tooltip_ability_item_dark_moon_shard"                                                                                 "Dark Moon Shard"
      "DOTA_Tooltip_ability_item_dark_moon_shard_Description"                                                                     "<h1>Use: Consume</h1> Reduces base attack time by %base_attack_time_reduction%%%. Can be used once per game."
      "DOTA_Tooltip_modifier_item_dark_moon_shard"                                                                                "Dark Moon Shard"
