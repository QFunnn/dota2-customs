      //=================================================================================================================
      // Drow Ranger
      //=================================================================================================================
        "DOTA_Tooltip_modifier_drow_ranger_trueshot_lua_aura_effect"                                                              "Precision Aura"
        "DOTA_Tooltip_modifier_drow_ranger_trueshot_lua_aura_effect_Description"                                                  "Attack damage increased by %dMODIFIER_PROPERTY_PREATTACK_BONUS_DAMAGE%"
        "DOTA_Tooltip_ability_drow_ranger_trueshot_lua"                                                                           "Precision Aura"
        "DOTA_Tooltip_ability_drow_ranger_trueshot_lua_Description"                                                               "Increases physical damage of all allied <font color='#FF7800'>ranged</font> heroes, based on ability owner's agility. Activating ability grants this bonus to ranged creeps for 30 seconds."
        "DOTA_Tooltip_ability_drow_ranger_trueshot_lua_Lore"                                                                      "Spending her solitude in endless training, Traxex learned to pass fraction of her mastery to any archer."
        "DOTA_Tooltip_ability_drow_ranger_trueshot_lua_trueshot_ranged_damage"                                                    "%BONUS DAMAGE:"
        "DOTA_Tooltip_ability_drow_ranger_trueshot_lua_radius"                                                                    "RADIUS:"
        "DOTA_Tooltip_ability_drow_ranger_marksmanship_custom"                                                                    "Marksmanship"
        "DOTA_Tooltip_ability_drow_ranger_marksmanship_custom_Description"                                                        "Combat experience allows hero to shoot more accurately and effectively. Each attack has chance to release arrow ignoring enemy's base armor. Also grants hero and nearby ranged allies bonus agility based on owner's agility. Ability doesn't work if there are enemy heroes within %disable_range% radius of its owner."
        "DOTA_Tooltip_ability_drow_ranger_marksmanship_custom_split_count_scepter"                                                "BONUS ARROWS:"
        "DOTA_Tooltip_ability_drow_ranger_marksmanship_custom_damage_reduction_scepter"                                           "%ARROW DAMAGE REDUCTION:"
        "DOTA_Tooltip_ability_drow_ranger_marksmanship_custom_Lore"                                                               "Traxex is embodiment of archery mastery."
        "DOTA_Tooltip_ability_drow_ranger_marksmanship_custom_Note0"                                                              "Triggered attack has True Strike effect."
        "DOTA_Tooltip_ability_drow_ranger_marksmanship_custom_chance"                                                             "%CHANCE:"
        "DOTA_Tooltip_ability_drow_ranger_marksmanship_custom_bonus_damage"                                                       "PROC DAMAGE:"
        "DOTA_Tooltip_ability_drow_ranger_marksmanship_custom_agility_multiplier"                                                 "%BONUS AGILITY:"
        "DOTA_Tooltip_ability_drow_ranger_marksmanship_custom_agility_range"                                                      "ENEMY HERO SEARCH RADIUS:"
        "DOTA_Tooltip_modifier_drow_ranger_marksmanship_custom_effect"                                                            "Marksmanship Aura"
        "DOTA_Tooltip_modifier_drow_ranger_marksmanship_custom_effect_description"                                                "Gaining %dMODIFIER_PROPERTY_STATS_AGILITY_BONUS% bonus agility."
        "DOTA_Tooltip_ability_drow_ranger_frost_arrows_custom"                                                                    "Frost Arrows"
        "DOTA_Tooltip_ability_drow_ranger_frost_arrows_custom_Description"                                                        "Adds freezing effect to hero's attacks, slowing target's movement for %duration% sec. and dealing bonus damage."
        "DOTA_Tooltip_ability_drow_ranger_frost_arrows_custom_scepter_description"                                                "Ability applies hypothermia to enemy. Each such effect reduces health regeneration and increases damage from this ability. If target dies under hypothermia effect, shards will scatter from it to all enemies around, dealing magical damage per effect and slowing victims."
        "DOTA_Tooltip_ability_drow_ranger_frost_arrows_custom_shard_regen_reduction_pct_per_stack"                                "%HEALTH REGEN REDUCTION PER EFFECT:"
        "DOTA_Tooltip_ability_drow_ranger_frost_arrows_custom_shard_bonus_damage_per_stack"                                       "BONUS DAMAGE PER EFFECT:"
        "DOTA_Tooltip_ability_drow_ranger_frost_arrows_custom_shard_stack_duration"                                               "EFFECT DURATION:"
        "DOTA_Tooltip_ability_drow_ranger_frost_arrows_custom_shard_burst_radius"                                                 "SHARD SCATTER RADIUS:"
        "DOTA_Tooltip_ability_drow_ranger_frost_arrows_custom_shard_burst_damage_per_stack"                                       "SHARD DAMAGE PER EFFECT:"
        "DOTA_Tooltip_ability_drow_ranger_frost_arrows_custom_shard_burst_move_slow_pct"                                          "%MOVEMENT SPEED SLOW FROM SHARDS:"
        "DOTA_Tooltip_ability_drow_ranger_frost_arrows_custom_shard_burst_slow_duration"                                          "SLOW DURATION FROM SHARDS:"
        "DOTA_Tooltip_ability_drow_ranger_frost_arrows_custom_shard_max_stacks"                                                   "MAX EFFECTS:"
        "DOTA_Tooltip_ability_drow_ranger_frost_arrows_custom_Lore"                                                               "Ice-covered arrows silently pierce air, freezing enemies through and through."
        "DOTA_Tooltip_ability_drow_ranger_frost_arrows_custom_Note0"                                                              "Each hit refreshes countdown until slow ends."
        "DOTA_Tooltip_ability_drow_ranger_frost_arrows_custom_frost_arrows_movement_speed"                                        "%SLOW:"
        "DOTA_Tooltip_ability_drow_ranger_frost_arrows_custom_damage"                                                             "BONUS DAMAGE:"
        "DOTA_Tooltip_ability_drow_ranger_frost_arrows_custom_percent_damage"                                                     "%DAMAGE FROM CURRENT HEALTH:"
        "DOTA_Tooltip_ability_drow_ranger_frost_arrows_custom_frost_arrows_abilityduration"                                       "DURATION:"
        "DOTA_Tooltip_modifier_drow_ranger_frost_arrows_custom_debuff"                                                            "Hypothermia"
        "DOTA_Tooltip_modifier_drow_ranger_frost_arrows_custom_debuff_Description"                                                "All healing, lifesteal and health regeneration reduced by %dMODIFIER_PROPERTY_HP_REGEN_AMPLIFY_PERCENTAGE%%%."
        "DOTA_Tooltip_ability_drow_ranger_multishot_custom"                                                                       "Multishot"
        "DOTA_Tooltip_ability_drow_ranger_multishot_custom_Description"                                                           "CHANNELING — hero releases one volley of arrows after another, dealing enemies portion of damage and applying enhanced Frost Arrows ability on them. Lasts up to %abilitychanneltime% sec."
        "DOTA_Tooltip_ability_drow_ranger_multishot_custom_Lore"                                                                  "When archer was young, her attempts to release multiple arrows at once were considered waste of time. In war of Ancients this skill became forced necessity."
        "DOTA_Tooltip_ability_drow_ranger_multishot_custom_wave_count"                                                            "WAVE COUNT:"
        "DOTA_Tooltip_ability_drow_ranger_multishot_custom_scepter_wave_count"                                                    "WAVE COUNT WITH SCEPTER:"
        "DOTA_Tooltip_ability_drow_ranger_multishot_custom_arrow_count_per_wave"                                                  "ARROWS PER WAVE:"
        "DOTA_Tooltip_ability_drow_ranger_multishot_custom_arrow_damage_pct"                                                      "%DAMAGE PORTION:"
        "DOTA_Tooltip_ability_drow_ranger_multishot_custom_arrow_slow_duration"                                                   "ARROW SLOW:"
        "DOTA_Tooltip_ability_drow_ranger_multishot_custom_arrow_range_multiplier"                                                "ATTACK RANGE MULTIPLIER:"
        "DOTA_Tooltip_ability_drow_ranger_multishot_custom_Note0"                                                                 "Base arrow damage pierces magic immunity."
        "DOTA_Tooltip_ability_drow_ranger_multishot_custom_Note1"                                                                 "Slow and bonus damage from Frost Arrows don't pierce magic immunity."
        "DOTA_Tooltip_ability_drow_ranger_marksmanship_custom_ability_note"                                                       "Bonus agility increased. Ability doesn't disable and works on melee heroes"
        "DOTA_Tooltip_ability_drow_ranger_multishot_custom_ability_note"                                                          "Significant stat improvements!"
