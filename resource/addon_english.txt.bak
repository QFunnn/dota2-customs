        "DOTA_Tooltip_ability_necrolyte_sadist_custom_slow_aoe"                                                                   "SLOW RADIUS:"
        "DOTA_Tooltip_ability_necrolyte_sadist_custom_bonus_damage"                                                               "%BONUS MAGICAL DAMAGE:"
        "DOTA_Tooltip_ability_necrolyte_sadist_custom_cooldown_scepter"                                                           "COOLDOWN:"
        "DOTA_Tooltip_ability_necrolyte_reapers_scythe_ability_note"                                                              "Can be cast on <font color='#B694FF'>creeps and Roshan.</font> Adds 1 ability stack per creep kill, once per round."
        "DOTA_Tooltip_ability_necrolyte_heartstopper_aura_lua"                                                                    "Heartstopper Aura"
        "DOTA_Tooltip_ability_necrolyte_heartstopper_aura_lua_Description"                                                        "Hero stops hearts of enemies around, causing them to gradually lose portion of maximum health. Also accelerates health and mana regen for %regen_duration% sec. for each killed creature."
        "DOTA_Tooltip_ability_necrolyte_heartstopper_aura_lua_aura_radius"                                                        "RADIUS:"
        "DOTA_Tooltip_ability_necrolyte_heartstopper_aura_lua_aura_damage"                                                        "%HEALTH REDUCTION:"
        "DOTA_Tooltip_modifier_necrolyte_heartstopper_aura_lua_effect"                                                            "Heartstopper Aura"
        "DOTA_Tooltip_modifier_necrolyte_heartstopper_aura_lua_effect_Description"                                                "Loses percentage of maximum health per second while near Necrophos."
        "DOTA_Tooltip_ability_necrolyte_heartstopper_aura_lua_Lore"                                                               "With souls of his victims Rotund'jere blurs line between life and death."
        "DOTA_Tooltip_ability_necrolyte_heartstopper_aura_lua_Note0"                                                              "Damage doesn't prevent using items like Blink Dagger."
        "DOTA_Tooltip_ability_necrolyte_heartstopper_aura_lua_Note1"                                                              "Doesn't affect Roshan and Goden."
        "DOTA_Tooltip_modifier_necrolyte_heartstopper_aura_lua"                                                                   "Heartstopper Aura"
        "DOTA_Tooltip_ability_necrolyte_heartstopper_aura_lua_health_regen"                                                       "HEALTH REGEN PER KILL:"
