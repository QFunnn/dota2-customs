        "DOTA_Tooltip_ability_ability_legion_commander_overwhelming_odds_Description"                                            "Turns the enemy's numerical superiority against them, dealing damage around the owner that increases with each enemy creep and hero hit. Also increases the owner's attack speed. Can be used during Duel.<br><br><span class='GameplayValues GameplayVariable'>Passive: Moment of Courage</span><br>May instantly respond to an enemy attack with a counterattack that grants bonus lifesteal."
        "DOTA_Tooltip_ability_ability_legion_commander_overwhelming_odds_duel_radius_bonus"                                      "BONUS RADIUS IN DUEL:"
        "DOTA_Tooltip_ability_ability_legion_commander_overwhelming_odds_duration"                                               "SPEED BUFF DURATION:"
        "DOTA_Tooltip_ability_ability_legion_commander_overwhelming_odds_Facet_legion_commander_stonehall_plate"                 "Damage dealt to enemies by Overwhelming Odds is converted into a barrier that absorbs all damage types."
        "DOTA_Tooltip_ability_ability_legion_commander_overwhelming_odds_hp_leech_percent"                                       "%COUNTERATTACK LIFESTEAL:"
        "DOTA_Tooltip_ability_ability_legion_commander_overwhelming_odds_Lore"                                                   "The archers of Stonehall are always at Tresdin's command."
        "DOTA_Tooltip_ability_ability_legion_commander_overwhelming_odds_moment_of_courage_cooldown"                             "COUNTERATTACK COOLDOWN:"
        "DOTA_Tooltip_ability_ability_legion_commander_overwhelming_odds_radius"                                                 "RADIUS:"
        "DOTA_Tooltip_ability_ability_legion_commander_overwhelming_odds_shard_description"                                     "Increases this ability's radius by %duel_radius_bonus% when used during Duel."
        "DOTA_Tooltip_ability_ability_legion_commander_overwhelming_odds_shield_duration"                                        "BARRIER DURATION:"
        "DOTA_Tooltip_ability_ability_legion_commander_overwhelming_odds_shield_per_damage_pct"                                  "%BARRIER HEALTH FROM DAMAGE:"
        "DOTA_Tooltip_ability_ability_legion_commander_overwhelming_odds_trigger_chance"                                         "%COUNTERATTACK CHANCE:"
        "DOTA_Tooltip_ability_legion_commander_press_the_attack_custom_ability_note"                                              "Ability instantly applies to hero, granting status immunity and increasing magic resistance by 60%."
        "DOTA_Tooltip_ability_legion_commander_press_the_attack_custom"                                                           "Press The Attack"
        "DOTA_Tooltip_ability_legion_commander_press_the_attack_custom_Description"                                               "Removes all debuffs from allied target, temporarily increasing movement speed and health regeneration.\n\nDISPEL TYPE: strong"
        "DOTA_Tooltip_ability_legion_commander_press_the_attack_custom_Lore"                                                      "The rallying horn of the Bronze Legion can inspire anyone."
        "DOTA_Tooltip_ability_legion_commander_press_the_attack_custom_duration"                                                  "DURATION:"
        "DOTA_Tooltip_ability_legion_commander_press_the_attack_custom_move_speed"                                                "%BONUS MOVEMENT SPEED:"
        "DOTA_Tooltip_ability_legion_commander_press_the_attack_custom_hp_regen"                                                  "HEALTH REGENERATION:"
        "DOTA_Tooltip_modifier_legion_commander_press_the_attack_custom_buff"                                                     "Press the Attack"
