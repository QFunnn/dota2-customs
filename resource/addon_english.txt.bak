      //=================================================================================================================
        "DOTA_Tooltip_ability_phoenix_fire_spirits_shard_description"                                                             ""
        "DOTA_Tooltip_ability_ability_phoenix_supernova"                                                                          "Supernova"
        "DOTA_Tooltip_ability_ability_phoenix_supernova_Description"                                                              "Hero ends its life for chance to be reborn. It transforms into burning sun that can be destroyed by enemy hero attacks. Sun burns enemies in large radius, and after %abilityduration% sec. explodes, stunning all enemies around. Hero appears at explosion site with full health, mana and without cooldown on other abilities.\n\nDISPEL TYPE: strong"
        "DOTA_Tooltip_ability_ability_phoenix_supernova_scepter_description"                                                      "Increases number of attacks to destroy sun, and also allows casting this ability on allied hero to be reborn together with them."
        "DOTA_Tooltip_ability_ability_phoenix_supernova_Lore"                                                                     "Solar heat of supernova can be deadly, but from its flame new rays rush into infinity."
        "DOTA_Tooltip_ability_ability_phoenix_supernova_aura_radius"                                                              "RADIUS:"
        "DOTA_Tooltip_ability_ability_phoenix_supernova_abilityduration"                                                          "DURATION:"
