        "DOTA_Tooltip_ability_invoker_ghost_walk_lua_Note0"                                                                       "Doesn't slow magic immune enemies."
        "DOTA_Tooltip_ability_invoker_tornado_lua"                                                                                "Tornado"
        "DOTA_Tooltip_ability_invoker_tornado_lua_Description"                                                                    "Releases swift tornado that lifts enemies in its path into air, then drops them to ground. Opponents take damage from fall."
        "DOTA_Tooltip_ability_invoker_tornado_lua_Lore"                                                                           "Tormarus' cursed barbs."
        "DOTA_Tooltip_ability_invoker_tornado_lua_Note0"                                                                          "Lifted enemies are invulnerable, but they take fall damage."
        "DOTA_Tooltip_ability_invoker_tornado_lua_travel_distance"                                                                "TRAVEL DISTANCE:"
