        "DOTA_Tooltip_ability_invoker_tornado_lua_base_damage"                                                                    "DAMAGE:"
        "DOTA_Tooltip_ability_invoker_emp_lua"                                                                                    "EMP"
        "DOTA_Tooltip_ability_invoker_emp_lua_Description"                                                                        "Creates concentrated energy clot that after %delay% seconds explodes, burning mana from all enemies in area of effect. Each unit of burned mana deals damage to enemies and restores 0.5 mana to ability owner. Hero restores 50%% of burned mana."
        "DOTA_Tooltip_ability_invoker_emp_lua_Lore"                                                                               "Endoleon's malevolent perturbation."
        "DOTA_Tooltip_ability_invoker_emp_lua_Note0"                                                                              "Doesn't affect units lifted in air (e.g. with Tornado or Eul's Scepter of Divinity)."
