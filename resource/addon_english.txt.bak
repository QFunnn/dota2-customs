        "DOTA_Tooltip_ability_ability_pugna_nether_blast_radius"                                                                 "RADIUS:"
        "DOTA_Tooltip_ability_pugna_ward_winter_2018"                                                                             "Saprophytic Ward"
        "DOTA_Tooltip_ability_pugna_ward_winter_2018_Description"                                                                 "Hero plants abyss ward that restores health to surrounding allies when they spend mana"
        "DOTA_Tooltip_ability_pugna_ward_winter_2018_aura_radius"                                                                 "AURA RADIUS:"
