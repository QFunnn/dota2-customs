      "DOTA_Tooltip_ability_item_recipe_torture_pipe_2_datadriven"                                                                "Recipe: Torture Pipe II"
      "DOTA_Tooltip_ability_item_torture_pipe_2_datadriven"                                                                       "Torture Pipe II"
