        "DOTA_Tooltip_ability_invoker_emp_lua_shard_description"                                                                  "Increases damage per mana unit burned by this ability, and pulls enemies toward center at %shard_drag_speed% units per second."
        "DOTA_Tooltip_ability_invoker_alacrity_lua"                                                                               "Alacrity"
        "DOTA_Tooltip_ability_invoker_alacrity_lua_Description"                                                                   "Causes ally surge of strength, increasing their attack speed and raising attack damage."
        "DOTA_Tooltip_ability_invoker_alacrity_lua_Lore"                                                                          "Gaster's mandate of impetuous inclination."
