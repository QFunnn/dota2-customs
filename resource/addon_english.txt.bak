        "DOTA_Tooltip_ability_shredder_chakram_2_lua_ability_note"                                                                ""
        "DOTA_Tooltip_ability_shredder_whirling_death_shard_description"                                                          "Adds new ability - Flamethrower"
        "DOTA_Tooltip_Ability_special_bonus_unique_cha_timbersaw"                                                                 "+{s:bonus_pass_damage} to instant / +{s:bonus_damage_per_second} periodic damage from Chakram and Second Chakram"
