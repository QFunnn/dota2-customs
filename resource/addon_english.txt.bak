      // Dark willow
      //=================================================================================================================
        "DOTA_Tooltip_ability_dark_willow_shadow_realm_ability_note"                                                              ""
        "DOTA_Tooltip_ability_dark_willow_bedlam_ability_note"                                                                    "Significant stat improvements!"
      //=================================================================================================================
      // Disruptor
      //=================================================================================================================
        "DOTA_Tooltip_ability_ability_disruptor_kinetic_field"                                                                   "Kinetic Field"
        "DOTA_Tooltip_ability_ability_disruptor_kinetic_field_Description"                                                       "After a short delay, creates a circular barrier of kinetic energy that enemies cannot pass through."
        "DOTA_Tooltip_ability_ability_disruptor_kinetic_field_duration"                                                          "DURATION:"
        "DOTA_Tooltip_ability_ability_disruptor_kinetic_field_formation_time"                                                    "FORMATION DELAY:"
        "DOTA_Tooltip_ability_ability_disruptor_kinetic_field_Lore"                                                              "The Stormcrafter has no fear of the hurricanes that engulf his enemies."
        "DOTA_Tooltip_ability_ability_disruptor_kinetic_field_Note0"                                                             "Spell immune enemies can pass through the barrier."
        "DOTA_Tooltip_ability_ability_disruptor_kinetic_field_radius"                                                            "RADIUS:"
        "DOTA_Tooltip_ability_ability_disruptor_aeon"                                                                             "Electromagnetic Disk"
        "DOTA_Tooltip_ability_ability_disruptor_aeon_Description"                                                                 "If hero's health drops below %health_threshold_pct%%%, they receive electromagnetic shield that with strong dispel removes most effects, and for %buff_duration% seconds increases status resistance by %status_resistance%%% and prevents dealing or taking damage.<br><br>Cooldown cannot be reset."
        "DOTA_Tooltip_modifier_ability_disruptor_aeon_buff"                                                                       "Electromagnetic Disk: Shield"
        "DOTA_Tooltip_modifier_ability_disruptor_aeon_buff_Description"                                                           "Grants %dMODIFIER_PROPERTY_STATUS_RESISTANCE_STACKING%%% status resistance and prevents dealing or taking damage."
        "DOTA_Tooltip_ability_disruptor_static_storm_custom"                                                                      "Static Storm"
        "DOTA_Tooltip_ability_disruptor_static_storm_custom_Description"                                                          "Creates static storm that deals damage and prevents all enemy creatures in specified area from using abilities. Damage increases with ability duration."
        "DOTA_Tooltip_ability_disruptor_static_storm_custom_Lore"                                                                 "Only native of Oglodi people can survive summer druudic gale."
        "DOTA_Tooltip_ability_disruptor_static_storm_custom_radius"                                                               "RADIUS:"
        "DOTA_Tooltip_ability_disruptor_static_storm_custom_damage_max"                                                           "MAX DAMAGE PER SECOND:"
        "DOTA_Tooltip_ability_disruptor_static_storm_custom_duration"                                                             "DURATION:"
        "DOTA_Tooltip_ability_disruptor_static_storm_custom_pulses"                                                               "PULSES:"
