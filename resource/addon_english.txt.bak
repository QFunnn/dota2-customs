        "DOTA_Tooltip_ability_broodmother_silken_bola_bonus_magic_damage"                                                          "BONUS MAGIC DAMAGE:"
        "DOTA_Tooltip_ability_broodmother_silken_bola_duration"                                                                    "DURATION:"
