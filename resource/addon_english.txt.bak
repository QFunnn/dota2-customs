        "DOTA_Tooltip_ability_lich_chain_frost_custom_slow_duration"                                                              "SLOW DURATION:"
        "DOTA_Tooltip_ability_lich_chain_frost_custom_bonus_jump_damage"                                                          "DAMAGE INCREASE:"
        "DOTA_Tooltip_ability_lich_chain_frost_custom_scepter_description"                                                        "Unlimited bounces."
        "DOTA_Tooltip_ability_lich_chain_frost_custom_shard_description"                                                          "Adds new ability - Ice Spire"
        "DOTA_Tooltip_modifier_lich_chain_frost_custom_slow"                                                                      "Chain Frost Slow"
        "DOTA_Tooltip_modifier_lich_chain_frost_custom_slow_Description"                                                          "Movement speed reduced by %dMODIFIER_PROPERTY_MOVESPEED_BONUS_PERCENTAGE%%%, attack speed reduced by %dMODIFIER_PROPERTY_ATTACKSPEED_BONUS_CONSTANT%."
        "DOTA_Tooltip_ability_ability_lich_frost_shield"                                                                          "Frost Shield"
        "DOTA_Tooltip_ability_ability_lich_frost_shield_Description"                                                              "Applies magical ice shield to target, reducing attack damage taken. While shield is active, it deals small magical damage to enemy creatures around every %interval% sec. and slows them."
