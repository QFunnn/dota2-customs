        "DOTA_Tooltip_ability_grimstroke_spirit_walk_custom_abilitycastrange"                                                     "CAST RANGE:"
        "DOTA_Tooltip_ability_grimstroke_spirit_walk_custom_damage_pct_per_sec"                                                   "%DAMAGE PER SECOND FROM MAX HEALTH:"
        "DOTA_Tooltip_ability_special_bonus_unique_grimstroke_4"                                                                  "+{s:bonus_damage_pct_per_sec}% damage from enemy max health per second from Ink Swell"
        "DOTA_Tooltip_ability_grimstroke_return_custom"                                                                           "Ink Explosion"
        "DOTA_Tooltip_ability_grimstroke_return_custom_Description"                                                               "Activates Ink Swell ability effect."
        "DOTA_Tooltip_ability_grimstroke_spirit_walk_custom_ability_note"                                                         "Ability applies to all targets in radius."
