        "DOTA_Tooltip_ability_troll_warlord_fervor_custom"                                                                        "Fervor"
        "DOTA_Tooltip_ability_troll_warlord_fervor_custom_Description"                                                            "Each subsequent attack on same target increases hero's attack speed. If changing target, speed decreases by half."
        "DOTA_Tooltip_ability_troll_warlord_fervor_custom_Lore"                                                                   "If didn't succeed first time — hit again and again."
        "DOTA_Tooltip_ability_troll_warlord_fervor_custom_attack_speed"                                                           "ATTACK SPEED PER EFFECT:"
        "DOTA_Tooltip_ability_troll_warlord_fervor_custom_max_stacks"                                                             "MAX EFFECT COUNT:"
        "DOTA_Tooltip_ability_troll_warlord_fervor_custom_shard_description"                                                      "Increases maximum effect count by %bonus_max_stacks% and grants owner chance to make bonus ranged attack on random enemy within attack range + %range_buffer%. Bonus attack chance: %base_chance%%% + %extra_attack_chance_per_stack%%% per Fervor effect."
        "DOTA_Tooltip_modifier_troll_warlord_fervor_custom"                                                                       "Fervor"
        "DOTA_Tooltip_modifier_troll_warlord_fervor_custom_Description"                                                           "Attack speed increased by %dMODIFIER_PROPERTY_ATTACKSPEED_BONUS_CONSTANT%."
        "DOTA_Tooltip_ability_troll_warlord_battle_trance_shard_description"                                                      ""
