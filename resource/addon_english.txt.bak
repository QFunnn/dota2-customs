        "DOTA_Tooltip_slardar_slithereen_crush_custom_puddle_buff_Description"                                                    "Under effect of Slardar's Slithereen Crush ability. Movement speed reduced by %dMODIFIER_PROPERTY_MOVESPEED_BONUS_PERCENTAGE%%%, attack speed reduced by %dMODIFIER_PROPERTY_ATTACKSPEED_BONUS_CONSTANT%."
