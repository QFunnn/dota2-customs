        "DOTA_Tooltip_ability_crystal_maiden_frostbite_custom_tick_rate"                                                          "DAMAGE INTERVAL:"
        "DOTA_Tooltip_ability_crystal_maiden_frostbite_custom_abilitycastrange"                                                   "CAST RANGE:"
        "DOTA_Tooltip_ability_crystal_maiden_frostbite_custom_radius"                                                             "EFFECT RADIUS:"
        "DOTA_Tooltip_modifier_crystal_maiden_frostbite_custom"                                                                   "Frostbite"
        "DOTA_Tooltip_ability_crystal_maiden_frostbite_custom_ability_note"                                                       "Creeps under berserk effect can move and attack"    
        "DOTA_Tooltip_modifier_crystal_maiden_frostbite_custom_Description"                                                       "Cannot move or attack."
        "DOTA_Tooltip_ability_crystal_maiden_freezing_field_ability_note"                                                         "Ability has reduced cooldown."
        "DOTA_Tooltip_ability_crystal_maiden_freezing_field_shard_description"                                                    ""
      //=================================================================================================================
      // Dark seer
      //=================================================================================================================
        "DOTA_Tooltip_ability_dark_seer_wall_of_replica_nb2017"                                                                   "Wall of Replica"
        "DOTA_Tooltip_ability_dark_seer_wall_of_replica_nb2017_Description"                                                       "Creates wall of refracted light that slows <font color='#70EA72'>any enemies</font> passing through it and creates their copies controlled by ability owner. <font color='#70EA72'>Hero can only have one copy of individual enemy unit at once</font> Illusions disappear if destroyed or when wall duration ends.\n\nUpgraded with Aghanim's Scepter."
        "DOTA_Tooltip_ability_dark_seer_wall_of_replica_Lore"                                                                     "While Ish'Kafel cannot return home, by mind's power he can summon prismatic wall fragment, causing confusion in enemy ranks."
        "DOTA_Tooltip_ability_dark_seer_wall_of_replica_nb2017_Note0"                                                             "Doesn't create illusions of other illusions."
        "DOTA_Tooltip_ability_dark_seer_wall_of_replica_nb2017_Note1"                                                             "Wall is 1000 units wide and created perpendicular to line between hero and cast point."
        "DOTA_Tooltip_ability_dark_seer_wall_of_replica_nb2017_duration"                                                          "DURATION:"
        "DOTA_Tooltip_ability_dark_seer_wall_of_replica_nb2017_tooltip_outgoing"                                                  "%ILLUSION DAMAGE:"
        "DOTA_Tooltip_ability_dark_seer_wall_of_replica_nb2017_tooltip_replica_total_damage_incoming"                             "%DAMAGE TO ILLUSIONS:"
        "DOTA_Tooltip_ability_dark_seer_wall_of_replica_nb2017_range_tooltip"                                                     "CAST RANGE:"
        "DOTA_Tooltip_ability_dark_seer_wall_of_replica_nb2017_tooltip_outgoing_scepter"                                          "%ILLUSION DAMAGE WITH SCEPTER:"
        "DOTA_Tooltip_ability_dark_seer_wall_of_replica_nb2017_movement_slow"                                                     "%SLOW:"
        "DOTA_Tooltip_ability_dark_seer_wall_of_replica_nb2017_slow_duration"                                                     "SLOW DURATION:"
        "DOTA_Tooltip_ability_dark_seer_ion_shell_shard_description"                                                              ""
        "DOTA_Tooltip_ability_dark_seer_surge_shard_Description"                                                                  "Units under this ability effect leave behind trail with 150 radius, existing %trail_duration% sec., slowing enemies by %trail_move_slow%%% and dealing %trail_damage% damage per second at %trail_damage_interval% sec. interval. If auto-cast enabled, trail doesn't appear."
        "DOTA_Tooltip_ability_dark_seer_ion_shell_ability_note"                                                                   ""
