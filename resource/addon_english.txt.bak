      // Antimage
      //=================================================================================================================
        "DOTA_Tooltip_ability_antimage_blink_ability_note"                                                                        "Reduces cast range of abilities and items for enemy heroes in 1000 radius by 50%. Does not affect creeps."
      //=================================================================================================================
      // Bloodseeker
      //=================================================================================================================
        "DOTA_Tooltip_ability_bloodseeker_bloodrage_custom"                                                                       "Bloodrage"
        "DOTA_Tooltip_ability_bloodseeker_bloodrage_custom_Description"                                                           "Awakens bloodlust in creature, making it attack faster and deal more spell damage, but loses portion of health each second. Grants allied heroes half of attack speed."
        "DOTA_Tooltip_ability_bloodseeker_bloodrage_custom_Lore"                                                                  "Strygwyr shares his primal bloodlust with others."
        "DOTA_Tooltip_ability_bloodseeker_bloodrage_custom_duration"                                                              "DURATION:"
        "DOTA_Tooltip_ability_bloodseeker_bloodrage_custom_attack_speed"                                                          "BONUS ATTACK SPEED:"
        "DOTA_Tooltip_ability_bloodseeker_bloodrage_custom_spell_amp"                                                             "%BONUS SPELL DAMAGE:"
        "DOTA_Tooltip_ability_bloodseeker_bloodrage_custom_damage_pct"                                                            "%MAX HEALTH LOSS PER SECOND:"
        "DOTA_Tooltip_ability_bloodseeker_bloodrage_custom_shard_description"                                                     "Each attack under this ability's effect heals hero for %shard_max_health_dmg_pct%%% of victim's maximum health and deals same amount of physical damage. Works only on ability owner."
        "DOTA_Tooltip_ability_bloodseeker_bloodrage_custom_ability_note"                                                          "With shard: deals bonus damage based on target max health.<br>Proc interval: 0.2 sec."
        "DOTA_Tooltip_modiifer_bloodseeker_bloodrage_custom"                                                                      "Bloodrage"
        "DOTA_Tooltip_modiifer_bloodseeker_bloodrage_custom_Description"                                                          "Attack speed and spell damage increased. Taking periodic damage."
        "DOTA_Tooltip_ability_bloodseeker_blood_mist_custom"                                                                      "Blood Mist"
        "DOTA_Tooltip_ability_bloodseeker_blood_mist_custom_Description"                                                          "While ability is active, hero splashes his blood around, losing health but dealing damage to affected enemies and slowing them, and also gaining increased healing from Thirst. This ability cannot be disabled while it's on cooldown. All healing from own abilities above maximum health converts to barrier, having up to 50% of hero's maximum health and weakening by 2% each second."
        "DOTA_Tooltip_ability_bloodseeker_blood_mist_custom_hp_cost_per_second"                                                   "%DAMAGE / HEALTH LOSS PER SECOND:"
        "DOTA_Tooltip_ability_bloodseeker_blood_mist_custom_radius"                                                               "RADIUS:"
        "DOTA_Tooltip_ability_bloodseeker_blood_mist_custom_movement_slow"                                                        "%MOVEMENT SPEED SLOW:"
        "DOTA_Tooltip_ability_bloodseeker_blood_mist_custom_thirst_bonus_pct"                                                     "%BONUS HEALING FROM THIRST:"
        "DOTA_Tooltip_modifier_bloodseeker_blood_mist_custom"                                                                     "Blood Mist"
        "DOTA_Tooltip_modifier_bloodseeker_blood_mist_custom_Description"                                                         "Emits blood, dealing damage to enemies nearby and slowing them. Healing from Thirst increased."
        "DOTA_Tooltip_modifier_bloodseeker_blood_mist_custom_slow"                                                                "Blood Mist"
        "DOTA_Tooltip_modifier_bloodseeker_blood_mist_custom_slow_Description"                                                    "Bloodseeker slows this creature with his blood by %dMODIFIER_PROPERTY_MOVESPEED_BONUS_PERCENTAGE%%%."
        "DOTA_Tooltip_ability_bloodseeker_thirst_Description"                                                                    "The hero revels in enemies' wounds, gaining movement speed when any enemy hero's health drops below %min_bonus_pct%%%%. The lower the health, the stronger the effect. Bonuses from different enemies stack and allow exceeding the maximum movement speed."
        "DOTA_Tooltip_ability_bloodseeker_thirst_scepter_description"                                                           "Adds a new ability - Blood Mist."
      //=================================================================================================================
      // Bounty Hunter
      //=================================================================================================================
        "DOTA_Tooltip_ability_bounty_hunter_track_shard_description"                                                              ""
        "DOTA_Tooltip_ability_bounty_hunter_wind_walk_shard_description"                                                          "Replaces cooldown with 2 charges that restore in %AbilityChargeRestoreTime% sec., and allows casting this ability on allied heroes without breaking invisibility. Fade delay on allies — %ally_fade_time% sec."
        "DOTA_Tooltip_ability_bounty_hunter_track"                                                                                "Track"
        "DOTA_Tooltip_ability_ability_bounty_hunter_big_game_hunter"                                                              "Big Game Hunter"
        "DOTA_Tooltip_ability_ability_bounty_hunter_big_game_hunter_Description"                                                  "Each creep kill with Jinada ability grants hero additional %gpm_per_creep% gold per minute.<br><br>When removing Jinada all accumulated gold per minute is nullified."
        "DOTA_Tooltip_modifier_ability_bounty_hunter_big_game_hunter"                                                             "Big Game Hunter"
        "DOTA_Tooltip_modifier_ability_bounty_hunter_big_game_hunter_Description"                                                 "Current additional gold per minute"
