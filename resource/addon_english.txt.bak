        "DOTA_Tooltip_ability_undying_flesh_golem_custom_slow_duration"                                                           "SLOW DURATION:"
        "DOTA_Tooltip_ability_undying_flesh_golem_custom_str_percentage"                                                          "%BONUS STRENGTH:"
        "DOTA_Tooltip_ability_undying_flesh_golem_custom_movement_bonus"                                                          "BONUS MOVEMENT SPEED:"
        "DOTA_Tooltip_ability_undying_flesh_golem_custom_scepter_description"                                                     "Makes ability toggleable. Hero gains ability to pass through obstacles, and its effect becomes permanent."
