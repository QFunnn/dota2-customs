      //=================================================================================================================
      // Elder Titan
      //=================================================================================================================
        "DOTA_Tooltip_ability_elder_titan_ancestral_spirit"                                                                       "Ancestral Spirit(Unremovable)"
        "DOTA_Tooltip_ability_elder_titan_ancestral_spirit_ability_note"                                                         ""
        "DOTA_Tooltip_ability_ability_elder_titan_earth_splitter"                                                               "Earth Splitter"
        "DOTA_Tooltip_ability_ability_elder_titan_earth_splitter_crack_distance"                                                 "CRACK DISTANCE:"
        "DOTA_Tooltip_ability_ability_elder_titan_earth_splitter_crack_time"                                                     "CRACK DELAY:"
        "DOTA_Tooltip_ability_ability_elder_titan_earth_splitter_crack_width"                                                    "CRACK WIDTH:"
        "DOTA_Tooltip_ability_ability_elder_titan_earth_splitter_damage_pct"                                                     "%MAX HEALTH DAMAGE:"
        "DOTA_Tooltip_ability_ability_elder_titan_earth_splitter_Description"                                                    "The hero splits the earth, sending a crack in the chosen direction. After 3 seconds the rift collapses, slowing all caught enemies and dealing damage based on their max health. Half the damage is physical, half is magical.<br><br>Bosses don't take damage. Starting from wave 90, no one takes damage."
        "DOTA_Tooltip_ability_ability_elder_titan_earth_splitter_Lore"                                                          "The Titan tears apart all that he once created."
        "DOTA_Tooltip_ability_ability_elder_titan_earth_splitter_Note0"                                                         "Bosses don't take damage. Starting from wave 90, no one takes damage."
        "DOTA_Tooltip_ability_ability_elder_titan_earth_splitter_slow_duration"                                                  "SLOW DURATION:"
        "DOTA_Tooltip_ability_ability_elder_titan_earth_splitter_slow_pct"                                                       "%MOVEMENT SLOW:"
        "DOTA_Tooltip_modifier_ability_elder_titan_earth_splitter"                                                                "Earth Splitter"
        "DOTA_Tooltip_modifier_ability_elder_titan_earth_splitter_Description"                                                    "Slowed by %dMODIFIER_PROPERTY_MOVESPEED_BONUS_PERCENTAGE%%%."
        "DOTA_Tooltip_ability_elder_titan_earth_splitter_ability_note"                                                            "Ability has reduced cooldown.<br><br><font color='#f00'>Does not work on large creeps after wave 90.</font>"
        "DOTA_Tooltip_modifier_hero_unique_modifier_elder_titan_natural_order_debuff"                                             "Magic Resistance Reduction from Natural Order"
        "DOTA_Tooltip_modifier_hero_unique_modifier_elder_titan_natural_order_debuff_Description"                                 "Magic resistance reduced by %dMODIFIER_PROPERTY_MAGICAL_RESISTANCE_DIRECT_MODIFICATION%%%."
      //=================================================================================================================
      // Huskar
      //=================================================================================================================
        "DOTA_Tooltip_ability_huskar_burning_spear_custom"                                                                        "Burning Spear (FrostHeaven)"
        "DOTA_Tooltip_ability_huskar_burning_spear_custom_Description"                                                            "Hero ignites target <font color='#70EA72'>and enemies around target</font>, dealing additional damage over time with each attack. Damage over time from multiple attacks stacks. Each attack costs hero health. Burn lasts 6 seconds. <font color='#70EA72'>Burn damage is dealt immediately after first spear hits.</font>"
        "DOTA_Tooltip_ability_huskar_burning_spear_custom_Lore"                                                                   "Sacred warrior bathes weapon in his own blood and ignites it, so that enemies' pain overshadows his own."
        "DOTA_Tooltip_ability_huskar_burning_spear_custom_Note0"                                                                  "Effects of this ability stack with no limit."
        "DOTA_Tooltip_ability_huskar_burning_spear_custom_Note1"                                                                  "Cannot commit suicide with this ability."
        "DOTA_Tooltip_ability_huskar_burning_spear_custom_health_cost"                                                            "HEALTH PER ATTACK:"
        "DOTA_Tooltip_ability_huskar_burning_spear_custom_burn_damage"                                                            "DAMAGE OVER TIME:"
        "DOTA_Tooltip_ability_huskar_burning_spear_custom_radius"                                                                 "RADIUS:"
        "DOTA_Tooltip_ability_huskar_burning_spear_custom_spear_aoe"                                                              "<font color='#70EA72'>BURN RADIUS:</font>"
        "DOTA_Tooltip_ability_huskar_burning_spear_custom_ability_note"                                                           "Ability is affected by Huskar's <font color='#B694FF'>talents</font>"
        "DOTA_Tooltip_ability_huskar_burning_spear_custom_scepter_description"                                                    ""
        "DOTA_Tooltip_ability_huskar_burning_spear_custom_shard_description"                                                      ""
        "DOTA_Tooltip_ability_huskar_burning_spear_scepter_description"                                                           ""
        "DOTA_Tooltip_ability_huskar_burning_spear_shard_description"                                                             ""
        "DOTA_Tooltip_modifier_huskar_burning_spear_custom_debuff"                                                                "Burning Spear"
        "DOTA_Tooltip_ability_huskar_inner_fire_custom"                                                                           "Inner Fire"
        "DOTA_Tooltip_ability_huskar_inner_fire_custom_Description"                                                               "Hero's fiery rage pushes all nearby enemies away from him, deals damage and disarms them."
        "DOTA_Tooltip_ability_huskar_inner_fire_custom_shard_description"                                                         "Ability can be used while stunned. Reduces cooldown by 3 seconds and removes cast animation."
        "DOTA_Tooltip_ability_huskar_inner_fire_custom_Lore"                                                                      "Even Huskar's own flesh cannot contain the overwhelming life force within him."
        "DOTA_Tooltip_ability_huskar_inner_fire_custom_damage"                                                                    "DAMAGE:"
        "DOTA_Tooltip_ability_huskar_inner_fire_custom_disarm_duration"                                                           "DURATION:"
        "DOTA_Tooltip_ability_huskar_inner_fire_custom_radius"                                                                    "RADIUS:"
        "DOTA_Tooltip_ability_huskar_inner_fire_custom_knockback_distance"                                                        "KNOCKBACK DISTANCE:"
        "DOTA_Tooltip_ability_huskar_inner_fire_custom_movement_slow_pct"                                                         "%MOVEMENT SLOW:"
        "DOTA_Tooltip_ability_huskar_inner_fire_custom_hero_damage_heal_pct"                                                      "%HEAL FROM HERO DAMAGE:"
        "DOTA_Tooltip_ability_huskar_inner_fire_custom_creep_damage_heal_pct"                                                     "%HEAL FROM CREEP DAMAGE:"
        "DOTA_Tooltip_modifier_huskar_inner_fire_custom_debuff"                                                                "Inner Fire"
        "DOTA_Tooltip_modifier_huskar_inner_fire_custom_debuff_Description"                                                    "Disarmed."
      //=================================================================================================================
