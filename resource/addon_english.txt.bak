      "DOTA_Tooltip_ability_item_torture_pipe_2_datadriven_bonus_mana_regen"                                                      "+$mana_regen"
      "DOTA_Tooltip_ability_item_torture_pipe_2_datadriven_bonus_health_regen"                                                    "+$hp_regen"
      "DOTA_Tooltip_ability_item_torture_pipe_2_datadriven_bonus_magic_resist"                                                    "%+$spell_resist"
      "DOTA_Tooltip_ability_item_torture_pipe_2_datadriven_dot_amplify"                                                           "%+DOT DAMAGE PER ATTRIBUTE"

      "DOTA_Tooltip_Ability_item_hellmask"                                                                                        "HellMask"
      "DOTA_Tooltip_Ability_item_recipe_hellmask"                                                                                 "Recipe: HellMask"
      "DOTA_Tooltip_ability_item_hellmask_Description"                                                                            "<h1>Active: Unholy Rage</h1> Increases lifesteal effect to %unholy_lifesteal_total_tooltip%%% for %unholy_duration% sec.<br><br>Dispel type: <span class=\"GameplayValues GameplayVariable\">normal</span>\n<h1>Passive: Assault Aura</h1> Increases armor of allied buildings and units by %aura_positive_armor%, and their attack speed by %aura_attack_speed%. Reduces enemy armor by %aura_negative_armor%.<br><br>Radius: %aura_radius%\n<h1>Passive: HellMask</h1> For killing creep permanently adds +%bonus_armor_per_stack% armor and +%bonus_damage_per_stack% damage to item (similar to Flash Heap for Pudge).<br><br> Bonus armor is disabled if enemy hero is within %armor_bonus_radius% radius."
      "DOTA_Tooltip_ability_item_hellmask_Lore"                                                                                   ""
      "DOTA_Tooltip_ability_item_hellmask_bonus_attack_speed"                                                                     "+$attack"
      "DOTA_Tooltip_ability_item_hellmask_bonus_armor"                                                                            "+$armor"
      "DOTA_Tooltip_ability_item_hellmask_bonus_strength"                                                                         "+$str"
      "DOTA_Tooltip_ability_item_hellmask_bonus_damage"                                                                           "+$damage"
      "DOTA_Tooltip_ability_item_hellmask_lifesteal_percent"                                                                      "%+$lifesteal"

      "DOTA_Tooltip_modifier_item_hellmask_debuff"                                                                                "HellMask"
      "DOTA_Tooltip_modifier_item_hellmask_debuff_Description"                                                                    "Armor reduced by %dMODIFIER_PROPERTY_PHYSICAL_ARMOR_BONUS%"

      "DOTA_Tooltip_modifier_item_hellmask_buff"                                                                                  "HellMask"
      "DOTA_Tooltip_modifier_item_hellmask_buff_Description"                                                                      "Armor increased by %dMODIFIER_PROPERTY_PHYSICAL_ARMOR_BONUS%.\nAttack speed increased by %dMODIFIER_PROPERTY_ATTACKSPEED_BONUS_CONSTANT%."

      "DOTA_Tooltip_modifier_item_hellmask_active"                                                                                "Unholy Rage"
      "DOTA_Tooltip_modifier_item_hellmask_active_Description"                                                                    "Lifesteal increased to 300%%"

      "DOTA_Tooltip_modifier_item_hellmask"                                                                                       "HellMask"
      "DOTA_Tooltip_modifier_item_hellmask_Description"                                                                           "Bonus armor for killing creeps increased by %fMODIFIER_PROPERTY_TOOLTIP% and damage by %dMODIFIER_PROPERTY_TOOLTIP2%"

      "DOTA_Tooltip_Ability_item_smoke_of_deceit_custom"                                                                          "Smoke of Deceit"
      "DOTA_Tooltip_ability_item_smoke_of_deceit_custom_Description"                                                              "<h1>Use: Disguise</h1> All player-controlled units and heroes in %application_radius% radius become invisible for %duration% seconds, and their movement speed increases by %bonus_movement_speed%%%. <br><br>If approaching enemy hero within %visibility_radius% distance, invisibility will be revealed.<br><br>Other invisibility-revealing effects do not work."
      "DOTA_Tooltip_ability_item_smoke_of_deceit_custom_Lore"                                                                     "The only worthy contribution of charlatan wizard Myrddin to the art of magic."
      "DOTA_Tooltip_ability_item_smoke_of_deceit_custom_ability_note"                                                            ""

      "DOTA_Tooltip_modifier_smoke_of_deceit_cha_custom"                                                                          "Smoke of Deceit"
      "DOTA_Tooltip_modifier_smoke_of_deceit_cha_custom_Description"                                                              "Invisible, moves %dMODIFIER_PROPERTY_MOVESPEED_BONUS_PERCENTAGE%%% faster, not displayed on enemy mini-map. Approaching enemy hero within 1200 distance will reveal invisibility."

      "DOTA_Tooltip_Ability_item_rapier_custom"                                                                                   "Divine Rapier"
      "DOTA_Tooltip_ability_item_rapier_custom_Description"                                                                       "<h1>Passive: Pierce</h1> Each attack has %truestrike_chance%%% chance to pierce evasion\n<h1>Passive: Everlasting</h1> <font color='#f00'>Bonus +%spell_amplify%% spell damage also applies to abilities dealing percentage magical damage.<br><br>Item loses one charge on death. When charges reach 0, item is destroyed</font>"
      "DOTA_Tooltip_ability_item_rapier_custom_Note0"                                                                             "If Divine Rapier is picked up by enemy of its first owner, it will drop only upon death of that enemy."
      "DOTA_Tooltip_ability_item_rapier_custom_Lore"                                                                              "Such a mighty weapon is not content with a single owner."
      "DOTA_Tooltip_ability_item_rapier_custom_bonus_damage"                                                                      "+$damage"
        
      "DOTA_Tooltip_Ability_item_butterfly_2"                                                                                     "Butterfly 2"
      "DOTA_Tooltip_Ability_item_butterfly_2_Description"          "Universal evasion chance — %bonus_universal_evasion%%%.\nUniversal evasion lets you fully avoid any incoming damage, not only attack damage. It triggers with a %evasion_cooldown%s cooldown against enemy heroes and their summons. Against neutral creeps it triggers without going on cooldown."
      "DOTA_Tooltip_ability_item_butterfly_2_Note0"                                                                               "Stacks diminishingly with other sources of evasion."
      "DOTA_Tooltip_ability_item_butterfly_2_Lore"                                                                                "Only the mightiest and most experienced warriors can tame this blade, but it grants its owner incredible agility in battle."
      "DOTA_Tooltip_ability_item_butterfly_2_bonus_agility"                                                                       "+$agi"
      "DOTA_Tooltip_ability_item_butterfly_2_bonus_evasion"                                                                       "%+$evasion"
      "DOTA_Tooltip_ability_item_butterfly_2_bonus_attack_speed"                                                                  "+$attack"
      "DOTA_Tooltip_ability_item_butterfly_2_bonus_damage"                                                                        "+$damage"
      "DOTA_Tooltip_ability_item_butterfly_2_bonus_movespeed"                                                                     "+$move_speed"
      "DOTA_Tooltip_ability_item_butterfly_2_bonus_attack_speed_pct"                                                              "%+$attack_pct"
      "DOTA_Tooltip_ability_item_butterfly_2_bonus_universal_evasion"                                                             "%UNIVERSAL EVASION CHANCE"

      "DOTA_Tooltip_Ability_item_bfury_2"                                                                                         "Battle Fury 2"
      "DOTA_Tooltip_ability_item_bfury_2_Description"                                                                             "<h1>Active: Chop Tree</h1> Cuts down selected tree.<br><br>Cast range: %abilitycastrange%\n<h1>Passive: Quell</h1> Increases attack damage against non-hero units by %quelling_bonus% for melee heroes and by %quelling_bonus_ranged% for ranged. \n<h1>Passive: Cleave</h1> Hero's attacks cleave through victim, dealing physical damage to enemies in %cleave_radius% radius around it (melee only).<br><br>• Damage to heroes: %cleave_damage_percent%%%<br>• Damage to creeps: %cleave_damage_percent_creep%%%"
      "DOTA_Tooltip_ability_item_bfury_2_Lore"                                                                                    "The owner of this mighty axe can mow down enemies in whole rows."
      "DOTA_Tooltip_ability_item_bfury_2_Note0"                                                                                   "Cleave damage pierces magic immunity."
      "DOTA_Tooltip_ability_item_bfury_2_Note1"                                                                                   "Each item or ability granting cleave deals damage separately from each other."
      "DOTA_Tooltip_ability_item_bfury_2_bonus_damage"                                                                            "+$damage"
      "DOTA_Tooltip_ability_item_bfury_2_bonus_health_regen"                                                                      "+$hp_regen"
      "DOTA_Tooltip_ability_item_bfury_2_bonus_mana_regen"                                                                        "+$mana_regen"
      "DOTA_Tooltip_ability_item_bfury_2_attack_range"                                                                            "+$attack_range_melee"

      "DOTA_Tooltip_Ability_item_bfury_3"                                                                                         "Eternal Battle Fury"
      "DOTA_Tooltip_Ability_item_recipe_bfury_2"                                                                                  "Recipe: Eternal Battle Fury"
      "DOTA_Tooltip_ability_item_bfury_3_Description"                                                                             "<h1>Active: Chop Tree</h1> Cuts down selected tree.<br><br>Cast range: %abilitycastrange%\n<h1>Passive: Quell</h1> Increases attack damage against non-hero units by %quelling_bonus% for melee heroes and by %quelling_bonus_ranged% for ranged. \n<h1>Passive: Cleave</h1> Increases your damage to creeps by %bonus_damage_creeps_no_late%%% (by %bonus_damage_creeps_late%%% after wave 40) and attacks deal %cleave_damage_percent%%% damage in %cleave_radius% radius around main target (melee only).<br><br><font color='#f00'>Disabled by break</font>"
      "DOTA_Tooltip_ability_item_bfury_3_Lore"                                                                                    "The owner of this mighty axe can mow down enemies in whole rows."
      "DOTA_Tooltip_ability_item_bfury_3_Note0"                                                                                   ""
      "DOTA_Tooltip_ability_item_bfury_3_Note1"                                                                                   ""
      "DOTA_Tooltip_ability_item_bfury_3_Note2"                                                                                   ""
      "DOTA_Tooltip_ability_item_bfury_3_bonus_damage"                                                                            "+$damage"
      "DOTA_Tooltip_ability_item_bfury_3_bonus_health_regen"                                                                      "+$hp_regen"
      "DOTA_Tooltip_ability_item_bfury_3_bonus_mana_regen"                                                                        "+$mana_regen"
      "DOTA_Tooltip_ability_item_bfury_3_attack_range"                                                                            "+$attack_range_melee"
      "DOTA_Tooltip_ability_item_bfury_3_attack_speed"                                                                            "+$attack"

      "DOTA_Tooltip_Ability_item_force_boots_custom"                                                                              "Force Boots"
      "DOTA_Tooltip_Ability_item_force_boots_custom_Description"                                                                  "<h1>Active: Force Push</h1>Pushes owner %push_length% in facing direction, dispels debuffs, restores %heal_restore% HP and grants a %barrier%-damage barrier for %duration% sec.\n\n<h1>Passive:</h1>Removes movement-speed limit on owner. Movement speed bonuses from multiple pairs of boots do not stack.\n\n<h1>Stats:</h1>+%bonus_movement_speed% movement speed<br>+%hp_regen% HP regen"
      "DOTA_Tooltip_Ability_item_force_boots_custom_Lore"                                                                         "Elusive curiosities that no one has managed to study, describe or classify."
    // Bonus stat labels intentionally omitted — values inline in Description's «Stats:».

      "DOTA_Tooltip_modifier_item_force_boots_custom_barrier"                                                                     "Force Boots"
      "DOTA_Tooltip_modifier_item_force_boots_custom_barrier_Description"                                                         "Ignores incoming damage"

      "DOTA_Tooltip_Ability_item_dagon_custom"                                                                                    "Dagon"
      "DOTA_Tooltip_ability_item_dagon_custom_Description"                                                                        "<h1>Active: Energy Burst</h1> Releases a powerful energy burst, dealing magical damage to selected enemy unit.<br><br>Disables <b><font color='#53ea48'>passive</font></b> abilities of selected target for %duration% sec.<br><br>Damage: %damage%<br>Cast range: %abilitycastrange%<br>Mana cost: %mana_cost_tooltip%"
      "DOTA_Tooltip_ability_item_dagon_custom_Lore"                                                                               "A magic wand that grows stronger over time, granting owner magic at their fingertips."
      "DOTA_Tooltip_ability_item_dagon_custom_Note0"                                                                              "Instantly kills illusions."
      "DOTA_Tooltip_ability_item_dagon_custom_bonus_int"                                                                          "+$int"
      "DOTA_Tooltip_ability_item_dagon_custom_bonus_str"                                                                          "+$str"
      "DOTA_Tooltip_ability_item_dagon_custom_bonus_agi"                                                                          "+$agi"

      "DOTA_Tooltip_Ability_item_dagon_2_custom"                                                                                  "Dagon"
      "DOTA_Tooltip_ability_item_dagon_2_custom_Description"                                                                      "<h1>Active: Energy Burst</h1> Releases a powerful energy burst, dealing magical damage to selected enemy unit.<br><br>Disables <b><font color='#53ea48'>passive</font></b> abilities of selected target for %duration% sec.<br><br>Damage: %damage%<br>Cast range: %abilitycastrange%<br>Mana cost: %mana_cost_tooltip%"
      "DOTA_Tooltip_ability_item_dagon_2_custom_Lore"                                                                             "A magic wand that grows stronger over time, granting owner magic at their fingertips."
      "DOTA_Tooltip_ability_item_dagon_2_custom_Note0"                                                                            "Instantly kills illusions."
      "DOTA_Tooltip_ability_item_dagon_2_custom_bonus_int"                                                                        "+$int"
      "DOTA_Tooltip_ability_item_dagon_2_custom_bonus_str"                                                                        "+$str"
      "DOTA_Tooltip_ability_item_dagon_2_custom_bonus_agi"                                                                        "+$agi"

      "DOTA_Tooltip_Ability_item_dagon_3_custom"                                                                                  "Dagon"
      "DOTA_Tooltip_ability_item_dagon_3_custom_Description"                                                                      "<h1>Active: Energy Burst</h1> Releases a powerful energy burst, dealing magical damage to selected enemy unit.<br><br>Disables <b><font color='#53ea48'>passive</font></b> abilities of selected target for %duration% sec.<br><br>Damage: %damage%<br>Cast range: %abilitycastrange%<br>Mana cost: %mana_cost_tooltip%"
      "DOTA_Tooltip_ability_item_dagon_3_custom_Lore"                                                                             "A magic wand that grows stronger over time, granting owner magic at their fingertips."
      "DOTA_Tooltip_ability_item_dagon_3_custom_Note0"                                                                            "Instantly kills illusions."
