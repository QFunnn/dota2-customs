      //=================================================================================================================
        "DOTA_Tooltip_ability_marci_innate"                                                                                       "Special Delivery"
        "DOTA_Tooltip_ability_marci_innate_Description"                                                                           "At <font color='#FFD700'>level 40</font>, hero gains active ability.<br><br>Hero applies magic protection that casts normal dispel and grants magic resistance and immunity to negative effects."
        "DOTA_Tooltip_ability_marci_innate_magical_resistance"                                                                    "%MAGIC RESISTANCE:"
        "DOTA_Tooltip_ability_marci_innate_duration"                                                                              "DURATION:"
        "DOTA_Tooltip_ability_ability_marci_special_delivery"                                                                     "Special Delivery"
        "DOTA_Tooltip_ability_ability_marci_special_delivery_ability_note"                                                        ""
        "DOTA_Tooltip_ability_ability_marci_special_delivery_Description"                                                         "Hero applies magic protection that casts normal dispel and grants magic resistance and immunity to negative effects."
        "DOTA_Tooltip_ability_ability_marci_special_delivery_magical_resistance"                                                  "%MAGIC RESISTANCE:"
        "DOTA_Tooltip_ability_ability_marci_special_delivery_duration"                                                            "DURATION:"
        "DOTA_Tooltip_modifier_ability_marci_special_delivery"                                                                    "Special Delivery"
        "DOTA_Tooltip_modifier_ability_marci_special_delivery_Description"                                                        "Grants magic resistance and immunity to negative effects."
        "DOTA_Tooltip_ability_ability_marci_unleash"                                                                             "Unleash"
        "DOTA_Tooltip_ability_ability_marci_unleash_charges_per_flurry"                                                         "HITS PER FURY COMBO:"
        "DOTA_Tooltip_ability_ability_marci_unleash_Description"                                                                 "The hero taps into their hidden power and gains fury charges, allowing rapid strikes that slow the target's movement and attack speed for %pulse_debuff_duration% sec. The final hit of each fury combo creates a damaging pulse around the target. After completing a fury combo, the hero cannot attack for %time_between_flurries% sec.\n\nActivating this ability grants +%bonus_movespeed%%% movement speed."
        "DOTA_Tooltip_ability_ability_marci_unleash_duration"                                                                    "DURATION:"
        "DOTA_Tooltip_ability_ability_marci_unleash_flurry_bonus_attack_speed"                                                   "BONUS ATTACK SPEED:"
        "DOTA_Tooltip_ability_ability_marci_unleash_Lore"                                                                        "Marci fights back against anyone who tries to discover the source of her power."
        "DOTA_Tooltip_ability_ability_marci_unleash_Note0"                                                                       "No more than 1 second can pass between attacks in a fury combo, otherwise the combo breaks."
        "DOTA_Tooltip_ability_ability_marci_unleash_Note1"                                                                       "Removes attack speed limit."
        "DOTA_Tooltip_ability_ability_marci_unleash_pulse_attack_slow_pct"                                                       "BASE ATTACK SPEED REDUCTION:"
        "DOTA_Tooltip_ability_ability_marci_unleash_pulse_damage"                                                                "PULSE DAMAGE:"
        "DOTA_Tooltip_ability_ability_marci_unleash_pulse_move_slow_pct"                                                         "%MOVEMENT SLOW:"
        "DOTA_Tooltip_ability_ability_marci_unleash_pulse_radius"                                                                "PULSE RADIUS:"
        "DOTA_Tooltip_ability_ability_marci_unleash_scepter_Description"                                                         "Reduces cooldown by %scepter_cooldown_reduction% sec. Activating this ability applies a basic dispel to the owner. While active, using other abilities creates a pulse. Pulses silence enemies for %pulse_silence_duration% sec.<br><br>DISPEL TYPE: Basic Dispel"
        "DOTA_Tooltip_modifier_ability_marci_unleash"                                                                            "Unleash"
        "DOTA_Tooltip_modifier_ability_marci_unleash_Description"                                                                "This hero's attacks form fury combos."
        "DOTA_Tooltip_modifier_ability_marci_unleash_debuff"                                                                     "Unleash Pulse"
        "DOTA_Tooltip_modifier_ability_marci_unleash_debuff_Description"                                                         "This unit's movement and attack speed are reduced."
        "DOTA_Tooltip_modifier_ability_marci_unleash_debuff_silence"                                                             "Unleash Pulse Silence"
        "DOTA_Tooltip_modifier_ability_marci_unleash_debuff_silence_Description"                                                 "This unit is silenced."
        "DOTA_Tooltip_modifier_ability_marci_unleash_fury"                                                                       "Unleash Fury"
        "DOTA_Tooltip_modifier_ability_marci_unleash_fury_Description"                                                           "Attack speed is significantly increased."
        "DOTA_Tooltip_modifier_ability_marci_unleash_recovery"                                                                   "Unleash Fury Recovery"
        "DOTA_Tooltip_modifier_ability_marci_unleash_recovery_Description"                                                       "Waiting for next fury strikes."
