      //=================================================================================================================
        "DOTA_Tooltip_ability_kunkka_ghostship_ability_note"                                                                      "Ability has reduced cooldown"
        "DOTA_Tooltip_ability_kunkka_torrent_storm_custom_ability_note"                                                           "Works without Torrent ability"
        "DOTA_Tooltip_ability_kunkka_tidebringer_custom"                                                                          "Tidebringer"
        "DOTA_Tooltip_ability_kunkka_tidebringer_custom_Description"                                                              "With his legendary sword, admiral strikes enemies in large area in front of him, dealing increased damage."
        "DOTA_Tooltip_ability_kunkka_tidebringer_custom_Lore"                                                                     "The lost soul of a Claddish officer has taken residence in the admiral's faithful blade, so that it may slay Cataract's demons."
        "DOTA_Tooltip_ability_kunkka_tidebringer_custom_damage_bonus"                                                             "BONUS DAMAGE:"
        "DOTA_Tooltip_ability_kunkka_tidebringer_custom_cleave_damage"                                                            "%CLEAVE DAMAGE:"
        "DOTA_Tooltip_ability_kunkka_tidebringer_custom_cleave_distance"                                                          "CLEAVE DISTANCE:"
        "DOTA_Tooltip_ability_kunkka_tidebringer_custom_attack_count"                                                             "ATTACK COUNT:"
        "DOTA_Tooltip_ability_kunkka_tidebringer_custom_ability_note"                                                             "Ability now procs after number of attacks made"
        "DOTA_Tooltip_modifier_kunkka_tidebringer_custom_passive"                                                                 "Tidebringer"
        "DOTA_Tooltip_modifier_kunkka_tidebringer_custom_passive_Description"                                                     "Attack count."
        "DOTA_Tooltip_modifier_kunkka_tidebringer_custom_slow"                                                                   "Tidebringer"
        "DOTA_Tooltip_modifier_kunkka_tidebringer_custom_slow_Description"                                                       "Movement speed slowed by %dMODIFIER_PROPERTY_MOVESPEED_BONUS_PERCENTAGE%%%"
        "DOTA_Tooltip_ability_kunkka_torrent_custom"                                                                           "Torrent"
        "DOTA_Tooltip_ability_kunkka_torrent_custom_Description"                                                                  "Creates water geyser that erupts from underground after some time. Geyser tosses enemies into air, stuns them and deals damage over time."
        "DOTA_Tooltip_ability_kunkka_torrent_custom_Lore"                                                                         "Summoning the element of Claddish Sea is the admiral's signature trick."
        "DOTA_Tooltip_ability_kunkka_torrent_custom_radius"                                                                       "RADIUS:"
        "DOTA_Tooltip_ability_kunkka_torrent_custom_movespeed_bonus"                                                              "%MOVEMENT SLOW:"
        "DOTA_Tooltip_ability_kunkka_torrent_custom_slow_duration"                                                                "SLOW DURATION:"
        "DOTA_Tooltip_ability_kunkka_torrent_custom_stun_duration"                                                                "STUN DURATION:"
        "DOTA_Tooltip_ability_kunkka_torrent_custom_delay"                                                                        "DELAY:"
        "DOTA_Tooltip_ability_kunkka_torrent_custom_torrent_damage"                                                               "TOTAL DAMAGE:"
        "DOTA_Tooltip_ability_kunkka_torrent_custom_scepter_description"                                                          "Adds new ability - Torrent Storm"
        "DOTA_Tooltip_ability_kunkka_torrent_storm_custom"                                                                        "Torrent Storm"
        "DOTA_Tooltip_ability_kunkka_torrent_storm_custom_Description"                                                            "Casts visible to all Torrent ability in random area around owner every %torrent_interval% sec. Radius: %torrent_max_distance%. Duration: %torrent_duration% sec."
        "DOTA_Tooltip_ability_kunkka_torrent_storm_custom_Lore"                                                                   "Hundreds of landlocked leagues cannot hold back the ocean tide."
        "DOTA_Tooltip_ability_kunkka_tidal_wave_ability_note"                                                                     ""
      //=================================================================================================================
      // Legion Commander
      //=================================================================================================================
        "DOTA_Tooltip_ability_custom_legion_commander_duel"                                                                       "Duel"
        "DOTA_Tooltip_ability_custom_legion_commander_duel_Description"                                                           "Challenges selected enemy hero to duel, where opponents are forced to attack each other for short period. They cannot use abilities or items. If one hero dies during duel, winner receives permanent bonus damage."
        "DOTA_Tooltip_ability_custom_legion_commander_duel_duration"                                                              "DURATION:"
        "DOTA_Tooltip_ability_custom_legion_commander_duel_reward_damage"                                                         "BONUS DAMAGE:"
        "DOTA_Tooltip_ability_custom_legion_commander_duel_duration_scepter"                                                      "SCEPTER DURATION:"
        "DOTA_Tooltip_ability_custom_legion_commander_duel_scepter_description"                                                   "Increases duel duration to 6.25/7/7.75 seconds. For its duration, owner gains status immunity."
        "DOTA_Tooltip_ability_custom_legion_commander_duel_Note0"                                                                 "Duel ends if participants move 2000 units apart."
        "DOTA_Tooltip_ability_custom_legion_commander_duel_Note1"                                                                 "If winning duel, hero receives Press the Attack effect."
        "DOTA_Tooltip_ability_custom_legion_commander_duel_Lore"                                                                  "A single combat with a Stonehall warrior is considered a great honor."
        "DOTA_Tooltip_ability_custom_legion_commander_duel_scepter_cooldown_reduction"                                            "COOLDOWN REDUCTION:"
        "DOTA_Tooltip_ability_custom_legion_commander_duel_scepter_damage_reduction_pct"                                          "%DAMAGE REDUCTION:"
        "DOTA_Tooltip_ability_custom_legion_commander_duel_ability_note"                                                          "Can be cast on <font color='#B694FF'>creeps.</font>"
        "DOTA_Tooltip_ability_custom_legion_commander_duel_shard_description"                                                     "Increases damage by %shard_duel_damage_bonus% for each win from start of game."
        "DOTA_Tooltip_modifier_duel_buff"                                                                                         "Duel"
        "DOTA_Tooltip_modifier_duel_buff_Description"                                                                             "Cannot leave duel until it ends or opponent dies."
        "DOTA_Tooltip_modifier_duel_damage"                                                                                       "Duel Damage"
        "DOTA_Tooltip_modifier_duel_damage_Description"                                                                           "Hero's damage increased from duel victories."
        "DOTA_Tooltip_ability_legion_commander_press_the_attack_shard_description"                                                ""
        "DOTA_Tooltip_ability_ability_legion_commander_overwhelming_odds"                                                        "Overwhelming Odds"
        "DOTA_Tooltip_ability_ability_legion_commander_overwhelming_odds_bonus_attack_speed"                                     "BONUS ATTACK SPEED:"
        "DOTA_Tooltip_ability_ability_legion_commander_overwhelming_odds_damage"                                                 "BASE DAMAGE:"
        "DOTA_Tooltip_ability_ability_legion_commander_overwhelming_odds_damage_per_hero"                                        "DAMAGE PER HERO:"
