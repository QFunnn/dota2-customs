        "DOTA_Tooltip_ability_chen_zealot"                                                                                       "Innate Ability"
        "DOTA_Tooltip_ability_chen_zealot_Description"                                                                           "Innate ability is temporarily disabled. It is being reworked and will be added soon."

        "DOTA_Tooltip_ability_chen_penitence_custom"                                                                              "Penitence"
        "DOTA_Tooltip_ability_chen_penitence_custom_Description"                                                                  "Forces enemy creature to move slower, and allies — to attack it faster."
        "DOTA_Tooltip_ability_chen_penitence_custom_Lore"                                                                         "While knight of faith cannot control enemy heroes like his animal flock, power of his persuasion can quite shake opponent's resolve."
        "DOTA_Tooltip_ability_chen_penitence_custom_duration"                                                                     "DURATION:"
        "DOTA_Tooltip_ability_chen_penitence_custom_bonus_movement_speed"                                                         "%MOVEMENT SLOW:"
        "DOTA_Tooltip_ability_chen_penitence_custom_bonus_attack_speed"                                                           "BONUS ATTACK SPEED:"
        "DOTA_Tooltip_ability_chen_penitence_custom_self_attack_range_bonus"                                                      "BONUS ATTACK RANGE:"
        "DOTA_Tooltip_modifier_chen_penitence_custom_buff"                                                                        "Penitence"
        "DOTA_Tooltip_modifier_chen_penitence_custom_buff_Description"                                                            "Attack speed increased by %dMODIFIER_PROPERTY_ATTACKSPEED_BONUS_CONSTANT%."
        "DOTA_Tooltip_modifier_chen_penitence_custom_debuff"                                                                      "Penitence"
        "DOTA_Tooltip_modifier_chen_penitence_custom_debuff_Description"                                                          "Movement slowed by %dMODIFIER_PROPERTY_MOVESPEED_BONUS_PERCENTAGE%%%. Attack speed against this creature increased."
        "DOTA_Tooltip_ability_special_bonus_unique_chen_11"                                                                       "Penitence deals 250 damage and becomes AOE with 500 radius."
        "DOTA_Tooltip_ability_chen_hand_of_god_custom"                                                                            "Hand of God"
        "DOTA_Tooltip_ability_chen_hand_of_god_custom_Description"                                                                "Heals all allied heroes and controlled creeps wherever they are and grants magic immunity. First applies strong healing, then periodic that lasts %hot_duration% sec."
        "DOTA_Tooltip_ability_chen_hand_of_god_custom_Lore"                                                                       "Using mental bond with his slaves, knight of faith maintains health and well-being of all who share his fanaticism."
        "DOTA_Tooltip_ability_chen_hand_of_god_custom_Note0"                                                                      "Heals invulnerable and hidden allies. Restores 5%%% health per second."
        "DOTA_Tooltip_ability_chen_hand_of_god_custom_ability_note"                                                                "Health regeneration is disabled during Snowball."
        "DOTA_Tooltip_ability_chen_hand_of_god_custom_heal_amount"                                                                "%INITIAL HEALING:"
        "DOTA_Tooltip_ability_chen_hand_of_god_custom_heal_per_second"                                                            "%HEALING PER SECOND:"
        "DOTA_Tooltip_ability_chen_hand_of_god_custom_status_resistance"                                                          "%MAGIC RESISTANCE:"
        "DOTA_Tooltip_ability_special_bonus_unique_chen_2"                                                                        "+20%/+2.5% to initial and periodic healing from Hand of God."
        "DOTA_Tooltip_modifier_chen_hand_of_god_custom"                                                                           "Hand of God"
        "DOTA_Tooltip_modifier_chen_hand_of_god_custom_Description"                                                               "Restores 5%%% health per second."
        "DOTA_Tooltip_modifier_chen_hand_of_god_custom_immunity"                                                                   "Hand of God"
        "DOTA_Tooltip_modifier_chen_hand_of_god_custom_immunity_Description"                                                       "Spell immunity. +80%% magic resistance."
        "DOTA_Tooltip_ability_chen_holy_persuasion_custom"                                                                        "Holy Persuasion"
        "DOTA_Tooltip_ability_chen_holy_persuasion_custom_Description"                                                            "Summons random set of creatures.<br><br> Check creature list with ALT"
        "DOTA_Tooltip_ability_chen_holy_persuasion_custom_Note0"                                                                  "Basic creatures<br>Call of the Wild(boar) <br>Count: 2 |  Duration: 60 seconds<br>Summon Wolves <br>Count: 2 |  Duration: 50 seconds<br>Zombies from Tombstone <br>Count: 5 |  Duration: 30 seconds<br>Skeletons from Vampiric Spirit <br>Count: 4 |  Duration: 60 seconds<br>Spawn Spiderlings <br>Count: 4 |  Duration: 60 seconds<br>Skeleton from Burning Army <br>Count: 2 |  Duration: 30 seconds<br>Plague Ward  <br>Count: 3 |  Duration: 40 seconds<br>Demonic Conversion <br>Count: 3 |  Duration: 40 seconds<br>Forge Spirit <br>Count: 2 |  Duration: 80 seconds<br>Nature's Call <br>Count: 4 |  Duration: 60 seconds<br><br>Ultimate creatures<br>Chaotic Offering <br>Count: 1 |  Duration: 60 seconds<br>Summon Familiars<br>Count: 1 |  Max count: 3<br>Mass Serpent Ward <br>Count: 2 |  Duration: 60 seconds<br>Nature's Call Shard<br>Count: 1 |  Duration: 60 seconds<br>Primal Split earth warrior <br>Count: 1 |  Duration: 20 seconds<br>Primal Split fire warrior <br>Count: 1 |  Duration: 20 seconds<br>Primal Split storm warrior <br>Count: 1 |  Duration: 20 seconds<br>Primal Split void warrior <br>Count: 1  |  Duration: 20 seconds"
        "DOTA_Tooltip_ability_chen_holy_persuasion_custom_ability_note"                                                           "Ability learned at level 1/6/13/19"
        "DOTA_Tooltip_ability_chen_holy_persuasion_custom_Lore"                                                                   "While they aren't knights, shepherd converts wild beasts into fellow believers same way he was once converted himself."
        "DOTA_Tooltip_ability_chen_holy_persuasion_custom_ultimate_unit"                                                          "ULTIMATE CREATURE LEVEL:"
        "DOTA_Tooltip_ability_chen_holy_persuasion_custom_basic_unit"                                                             "BASIC CREATURE LEVEL:"
        "DOTA_Tooltip_ability_chen_holy_persuasion_custom_movement_speed_bonus"                                                   "BONUS MOVEMENT SPEED:"
        "DOTA_Tooltip_ability_chen_holy_persuasion_custom_damage_bonus"                                                           "BONUS DAMAGE:"
        "DOTA_Tooltip_ability_chen_holy_persuasion_custom_health_min"                                                             "MIN HEALTH LEVEL:"
        "DOTA_Tooltip_ability_chen_holy_persuasion_custom_group_count"                                                            "GROUP COUNT:"
        "DOTA_Tooltip_ability_special_bonus_unique_chen_3"                                                                        "+1 group count for Holy Persuasion."
      //=================================================================================================================
      // Crystal maiden
      //=================================================================================================================
        "DOTA_Tooltip_ability_crystal_maiden_freezing_field_scepter_description"                                                  "Allows moving, attacking and casting spells during ability. Enemies can still interrupt it. Hero moves 75% slower. Increases explosion count by 20%."
        "DOTA_Tooltip_ability_crystal_maiden_frostbite_custom"                                                                    "Frostbite"
        "DOTA_Tooltip_ability_crystal_maiden_frostbite_custom_Description"                                                        "Encases opponent in ice, dealing them periodic damage and preventing movement and attacks. Lasts %creep_duration% sec. on creeps level 6 or lower."
        "dota_hud_error_cant_cast_frostbite_on_self"                                                                             "Cannot cast on self"
        "DOTA_Tooltip_ability_crystal_maiden_frostbite_custom_Lore"                                                               "Rylai summons cold wind from Blueheart Glacier iceberg that imprisons opponent in ice block."
        "DOTA_Tooltip_ability_crystal_maiden_frostbite_custom_Note0"                                                              "Applies root effect."
        "DOTA_Tooltip_ability_crystal_maiden_frostbite_custom_damage_per_second"                                                  "DAMAGE PER SECOND:"
        "DOTA_Tooltip_ability_crystal_maiden_frostbite_custom_duration"                                                           "DURATION ON HEROES:"
