      "VOTES_Header"                                                                                                                  "Voting"
      "VOTES_Header_desc"                                                                                                             "Choose one of the proposed options"
      "VOTES_LIST_MINIGAME_TYPE"                                                                                                      "Minigame vote"
      "VOTES_LIST_MINIGAME_TYPE_0"                                                                                                    "Arena Mode"
      "VOTES_LIST_MINIGAME_TYPE_0_desc"                                                                                               "You become skeleton warrior. You have Dagger, Shockwave and Refraction, and each hit against you grants guaranteed evasion from 2 attacks for 3 seconds."
      "VOTES_LIST_MINIGAME_TYPE_1"                                                                                                    "Pudge Wars"
      "VOTES_LIST_MINIGAME_TYPE_1_desc"                                                                                               "You become Pudge with Meat Hook and Phase Shift and can attack enemies with regular attacks."
      "VOTES_LIST_MINIGAME_TYPE_2"                                                                                                    "Mirana Wars"
      "VOTES_LIST_MINIGAME_TYPE_2_desc"                                                                                               "You become Mirana with Arrow and Leap and can attack enemies with regular attacks. Arrow doesn't deal damage to already stunned player."
      "VOTES_LIST_MINIGAME_TYPE_desc"                                                                                                 "Choose minigame for this round"
      "VOTES_LIST_ROUND_MODE"                                                                                                         "Mode vote"
      "VOTES_LIST_ROUND_MODE_0"                                                                                                       "Minigame"
      "VOTES_LIST_ROUND_MODE_0_desc"                                                                                                  "Round starts on special arena with vote for specific minigame, after voting selected minigame begins. During game random rune spawns in center of arena every 10 seconds."
      "VOTES_LIST_ROUND_MODE_1"                                                                                                       "Mass Arena"
      "VOTES_LIST_ROUND_MODE_1_desc"                                                                                                  "Free PVP arena between players.<br>Maximum arena duration 2 minutes.<br>Winner is last surviving player.<br>If multiple players alive when time expires - player with most health wins."
      "VOTES_LIST_ROUND_MODE_desc"                                                                                                    "Choose mode for next round"
      "VOTES_LIST_LAST_DUEL"                                                                                                          "Last duel vote"
      "VOTES_LIST_LAST_DUEL_0"                                                                                                        "Decline"
