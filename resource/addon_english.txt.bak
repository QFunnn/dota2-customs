  //=================================================================================================================
  // Items
  //=================================================================================================================

      "DOTA_Tooltip_Ability_item_panzer_custom"                                                                                   "Panzer"
    "DOTA_Tooltip_ability_item_panzer_custom_Description"                                                                         "<font color='#f00'><b>Item temporarily removed!</b></font>\n<h1>Active: Damage Return</h1>Increases damage return from all sources by %return_damage%%% and blocks %block_active%%% incoming damage. Lasts %duration_shield% seconds.<br><br>After the effect ends, the hero gains a shield from physical attacks of %phys_shield%%%. Shield duration %phys_shield_duration% seconds.\n\n<h1>Passive: Damage Block</h1> Has a %chance_block%%% chance to block %block_damage% damage.\n\n<h1>Passive: Damage Return</h1>Returns %passive_reflection_constant% + %passive_reflection_pct%%% damage from each attack to attacking creatures."
  "DOTA_Tooltip_ability_item_panzer_custom_Lore"                                                                                  "Razor-sharp armor — the choice of selfless martyrs."
  "DOTA_Tooltip_ability_item_panzer_custom_Note0"                                                                                 "Damage is returned in original amount, before reduction."
  "DOTA_Tooltip_ability_item_panzer_custom_Note1"                                                                                 "Does not reflect damage from other Blade Mails and similar abilities."
  "DOTA_Tooltip_ability_item_panzer_custom_Note2"                                                                                 "Returned damage has the same type as received."
    "DOTA_Tooltip_ability_item_panzer_custom_health_regen_perc"                                                                   "%+ max health per second"
  "DOTA_Tooltip_ability_item_panzer_custom_bonus_health"                                                                          "+$health"
  "DOTA_Tooltip_ability_item_panzer_custom_bonus_strength"                                                                        "+$str"
    "DOTA_Tooltip_ability_item_panzer_custom_bonus_armor"                                                                         "+$armor"
    
  "DOTA_Tooltip_modifier_item_panzer_custom_active"                                                                               "Attack Reflection"
  "DOTA_Tooltip_modifier_item_panzer_custom_active_Description"                                                                   "Returns damage to attacking creatures."

    "DOTA_Tooltip_modifier_item_panzer_custom_shield"                                                                             "Panzer"
  "DOTA_Tooltip_modifier_item_panzer_custom_shield_Description"                                                                   "Shield from physical attacks."


    "DOTA_Tooltip_Ability_item_kryptonyte_custom"                                                                                 "Kryptonite"
    "DOTA_Tooltip_ability_item_kryptonyte_custom_Description"                                                                     "<h1>Passive: Kryptonite</h1> Each spell and item use applies Phylactery effect to enemies in %radius% radius and additionally deals %bonus_spell_damage% magical damage.\n<h1>Passive: Magilys</h1> Magical damage has a %chance%%% chance to deal %critical_damage%%% critical damage. Cooldown %cooldown_crit% sec."
    "DOTA_Tooltip_ability_item_kryptonyte_custom_bonus_intellect"                                                                 "+$int"
    "DOTA_Tooltip_ability_item_kryptonyte_custom_bonus_health"                                                                    "+$health"
    "DOTA_Tooltip_ability_item_kryptonyte_custom_bonus_mana"                                                                      "+$mana"
    "DOTA_Tooltip_ability_item_kryptonyte_custom_bonus_all_stats"                                                                 "+$all"

      "DOTA_Tooltip_ability_special_bonus_unique_wraith_king_facet_3"                                                             "+{s:bonus_min_skeleton_spawn} Vampiric Spirit Skeletons"
      "DOTA_Tooltip_ability_special_bonus_unique_wraith_king_facet_1"                                                             "+{s:bonus_blast_dot_duration}s Wraithfire Blast DoT Duration"
      "DOTA_Tooltip_ability_special_bonus_unique_wraith_king_10_Description"                                                      "Mortal Strike is passively built into Wraithfire Blast."

    "DOTA_Tooltip_ability_special_bonus_custom_debuff_amp_15"                                                                     "+{s:value}% debuff duration"
    "DOTA_Tooltip_ability_special_bonus_custom_debuff_amp_10"                                                                     "+{s:value}% debuff duration"

    "DOTA_Tooltip_Ability_item_black_grimoire_custom"                                                                             "Black Grimoire"
  "DOTA_Tooltip_Ability_item_black_grimoire_custom_Description"                                                                   "<h1>Use: Profane Knowledge</h1>The item gains power with each creep or hero kill, gaining charges.<br><br>Charges per creep kill: %charges_per_creep%<br>Charges per hero kill: %charges_per_hero%<br><br>Right-clicking the item and selecting 'Use', the hero gains %xp_per_charge% experience per charge.<br><br><font color='#e03e2e'>This item cannot be dropped.</font>"

    "DOTA_Tooltip_modifier_item_panic_button_custom_buff"                                                                         "Magic Lamp"
    "DOTA_Tooltip_modifier_item_panic_button_custom_buff_Description"                                                             "Prevents dealing or receiving damage"


    "DOTA_Tooltip_Ability_item_hex_aoe"                                                                                           "Scythe of Vyse 2"
    "DOTA_Tooltip_Ability_item_recipe_hex_aoe"                                                                                    "Recipe: Scythe of Vyse 2"
    "DOTA_Tooltip_ability_item_hex_aoe_Description"                                                                               "<h1>Active: Hex</h1>Turns all targets in %aoe_radius% radius into harmless critters for %sheep_duration% seconds. Victims cannot attack, use abilities or items, and their base speed drops to %sheep_movement_speed%.<br>Instantly destroys illusions."
    "DOTA_Tooltip_ability_item_hex_aoe_Note0"                                                                                     "Victim has base speed of %sheep_movement_speed%, but does not lose effects granting maximum speed."
    "DOTA_Tooltip_ability_item_hex_aoe_ability_note"                                                                              "Summoned units and other non-hero creatures cannot block the effect of this item."
    "DOTA_Tooltip_ability_item_hex_aoe_Lore"                                                                                      "This relic, guarded by the Vyse cult, is coveted by any mage."
    "DOTA_Tooltip_ability_item_hex_aoe_bonus_intellect"                                                                           "+$int"
    "DOTA_Tooltip_ability_item_hex_aoe_bonus_mana_regen"                                                                          "+$mana_regen"

    "DOTA_Tooltip_modifier_item_hex_aoe_hex"                                                                                      "Hexed"
    "DOTA_Tooltip_modifier_item_hex_aoe_hex_Description"                                                                          "You are a pig. You cannot attack or use spells."

    "DOTA_Tooltip_Ability_item_halberd_aoe"                                                                                       "Heaven's Halberd 2"
    "DOTA_Tooltip_Ability_item_recipe_halberd_aoe"                                                                                "Recipe: Heaven's Halberd 2"
    "DOTA_Tooltip_ability_item_halberd_aoe_Description"                                                                           "<h1>Active: Disarm</h1>Removes power from all creatures in %aoe_radius% radius, preventing them from attacking. Disarm duration depends on victim's attack type: %disarm_melee% sec for melee and %disarm_range% sec for ranged.\n\n<h1>Passive: Damage Block</h1> Has a %block_chance%%% chance to block %block_damage_melee% damage from attacks if owner is melee hero, or %block_damage_ranged% damage if ranged hero."
    "DOTA_Tooltip_ability_item_halberd_aoe_Lore"                                                                                  "This halberd moves with the speed of a small blade, allowing its owner to win duels where a heavier weapon would fail."
    "DOTA_Tooltip_ability_item_halberd_aoe_ability_note"                                                                          "Summoned units and other non-hero creatures cannot block the effect of this item."

    "DOTA_Tooltip_ability_item_halberd_aoe_bonus_health"                                                                          "+$health"
    "DOTA_Tooltip_ability_item_halberd_aoe_bonus_health_regen"                                                                    "+$hp_regen"
    "DOTA_Tooltip_ability_item_halberd_aoe_bonus_all_stats"                                                                       "+$all"

    "DOTA_Tooltip_modifier_item_halberd_aoe_disarm"                                                                               "Disarmed"
    "DOTA_Tooltip_modifier_item_halberd_aoe_disarm_Description"                                                                   "Disarmed by Heaven's Halberd artifact, cannot attack."
    
    "DOTA_Tooltip_Ability_item_manta_style_2"                                                                                     "Manta Style 2"
    "DOTA_Tooltip_Ability_item_recipe_manta_style_2"                                                                              "Recipe: Manta Style 2"
    "DOTA_Tooltip_ability_item_manta_style_2_Description"                                                                         "<h1>Active: Mirror Image</h1>Creates %illusion_count% illusions of your hero that last %illusion_duration% sec.<br><br>Illusions take %illusion_damage_take%%% damage, and deal damage based on the owner's attack type: melee illusions deal %illusion_damage_melee%%% damage, and ranged illusions deal %illusion_damage_ranged%%%.<br><br>Can be used while stunned and silenced.<br><br>Dispel Type: <span class=\"GameplayValues GameplayVariable\">Strong</span>"
    "DOTA_Tooltip_ability_item_manta_style_2_Lore"                                                                                "An axe made of reflective materials that causes confusion in enemy ranks."
    "DOTA_Tooltip_ability_item_manta_style_2_Note0"                                                                               "Item is used for %invuln_duration% sec., and during this time the owner is invulnerable."
    "DOTA_Tooltip_ability_item_manta_style_2_Note1"                                                                               "Using removes almost all effects."
    "DOTA_Tooltip_ability_item_manta_style_2_Note2"                                                                               "Speed bonuses from multiple Yasha-based items do not stack."
    "DOTA_Tooltip_ability_item_manta_style_2_Note3"                                                                               "Can be used while stunned and silenced."
    "DOTA_Tooltip_ability_item_manta_style_2_bonus_agility"                                                                       "+$agi"
    "DOTA_Tooltip_ability_item_manta_style_2_bonus_strength"                                                                      "+$str"
    "DOTA_Tooltip_ability_item_manta_style_2_bonus_intellect"                                                                     "+$int"
    "DOTA_Tooltip_ability_item_manta_style_2_bonus_attack_speed"                                                                  "+$attack"
    "DOTA_Tooltip_ability_item_manta_style_2_bonus_movement_speed"                                                                "%+$move_speed"

    "DOTA_Tooltip_Ability_item_monkey_crest"                                                                                      "Monkey Crest"
    "DOTA_Tooltip_Ability_item_recipe_monkey_crest"                                                                               "Recipe: Monkey Crest"
    "DOTA_Tooltip_ability_item_monkey_crest_Description"                                                                          "<h1>Active: Radiant Mark</h1>Can be used on both enemies and allies within %mark_radius% radius.<br><br><span class=\"GameplayValues GameplayVariable\">Cast on allies/self:</span><br>Grants physical barrier for %mark_friendly_physical_barrier_pct%%% of target's max health, <span class=\"GameplayValues GameplayVariable\">Pierce effect with %mark_friendly_pierce_chance%%% chance</span>, +%mark_friendly_bonus_armor% armor, +%mark_friendly_bonus_attack_speed% attack speed and +%mark_friendly_bonus_movespeed_pct%%% movement speed.<br><br><span class=\"GameplayValues GameplayVariable\">Cast on enemies:</span><br>Causes miss chance of %mark_enemy_miss_chance%%%, -%mark_enemy_bonus_armor% armor, -%mark_enemy_bonus_attack_speed% attack speed and -%mark_enemy_bonus_movespeed_pct%%% movement speed.<br><br>Duration: %mark_duration% sec.<br><h1>Passive: Pierce</h1>Each attack has a %pierce_passive_chance%%% chance to pierce evasion (true strike) and deal +%pierce_damage% bonus magic damage."
    "DOTA_Tooltip_ability_item_monkey_crest_Note0"                                                                                "Shares cooldown with Pavise and Solar Crest"
    "DOTA_Tooltip_ability_item_monkey_crest_bonus_damage"                                                                         "+$damage"
    "DOTA_Tooltip_ability_item_monkey_crest_bonus_attack_speed"                                                                   "+$attack"
    "DOTA_Tooltip_ability_item_monkey_crest_bonus_all_stats"                                                                      "+$all"
    "DOTA_Tooltip_ability_item_monkey_crest_bonus_armor"                                                                          "+$armor"
    "DOTA_Tooltip_ability_item_monkey_crest_bonus_mana_regen"                                                                     "+$mana_regen"
    "DOTA_Tooltip_ability_item_monkey_crest_bonus_hp_regen"                                                                       "+$hp_regen"
    "DOTA_Tooltip_ability_item_monkey_crest_bonus_health"                                                                         "+$health"
    "DOTA_Tooltip_ability_item_monkey_crest_bonus_mana"                                                                           "+$mana"
    "DOTA_Tooltip_ability_item_monkey_crest_bonus_movement_speed"                                                                 "+$move_speed"
    "DOTA_Tooltip_ability_item_monkey_crest_bonus_attack_range_melee"                                                             "+ attack range (melee)"

        "DOTA_Tooltip_Ability_item_enhancement_fleetfooted_custom"                                                                "Fleetfooted"
        "DOTA_Tooltip_Ability_item_enhancement_fleetfooted_custom_movespeed"                                                      "+$move_speed"
        "DOTA_Tooltip_Ability_item_enhancement_fleetfooted_custom_Note0"                                                          "Does not stack with bonuses from any boots<br>"
        "DOTA_Tooltip_Ability_item_enhancement_fleetfooted_custom_Note1"                                                          "Removes movement speed limit"

        "DOTA_Tooltip_Ability_item_enhancement_evolved_custom"                                                                  "Evolved"
        "DOTA_Tooltip_Ability_item_enhancement_evolved_custom_Description"                                                      "Grants +40 to all attributes"
        "DOTA_Tooltip_Ability_item_enhancement_evolved_custom_bonus_all_stats"                                                  "+$all"

      "DOTA_Tooltip_ability_item_aegis_lua"                                                                                       "Aegis of Immortal"
      "DOTA_Tooltip_ability_item_aegis_lua_Description"                                                                           "<h1>Use: Immortal</h1>Adds 1 aegis"

      "DOTA_Tooltip_ability_item_saw_wheel"                                                                                       "Timber Saw Wheel"
      "DOTA_Tooltip_ability_item_saw_wheel_bonus_dmg"                                                                             "+$damage"
      "DOTA_Tooltip_ability_item_saw_wheel_bonus_all_attributes"                                                                  "+$all"
      "DOTA_Tooltip_ability_item_saw_wheel_Description"                                                                           "<h1>Active: Saw Whirling</h1>Spins extremely sharp edges, dealing damage to enemies in area.\n<h1>Passive Saw</h1>Melee Only-Whirling will deal additional damage and stun when destroying trees"
      "DOTA_Tooltip_ability_item_saw_wheel_damage"                                                                                "DAMAGE:"
      "DOTA_Tooltip_ability_item_saw_wheel_damage_with_tree"                                                                      "DAMAGE NEAR TREE:"
      "DOTA_Tooltip_ability_item_saw_wheel_stun_with_tree"                                                                        "STUN NEAR TREE:"

      "DOTA_Tooltip_Ability_item_refresher_custom"                                                                                "Refresher Orb"
      "DOTA_Tooltip_ability_item_refresher_custom_Description"                                                                    "<h1>Active: Reset</h1> Resets the cooldown of all your abilities."
      "DOTA_Tooltip_ability_item_refresher_custom_Lore"                                                                           "A powerful artifact created for mages."
      "DOTA_Tooltip_ability_item_refresher_custom_bonus_health_regen"                                                             "+$hp_regen"
      "DOTA_Tooltip_ability_item_refresher_custom_bonus_mana_regen"                                                               "+$mana_regen"
      "DOTA_Tooltip_ability_item_refresher_custom_ability_note"                                                                  ""

      "DOTA_Tooltip_ability_item_wraith_dominator"                                                                                "Wraith of Dominator"
      "DOTA_Tooltip_ability_item_wraith_dominator_Description"                                                                    "<h1>Active: Wraith's Reprisal</h1>Applies an effect to the hero that reduces all damage from enemies in %pact_aura_radius% radius by %damage_penalty_aura%%% and deals %aura_dps% damage per second to them. Allies gain %bonus_damage_aura_active%%% bonus damage. Effect duration %duration% sec.\n<h1>Passive: Vladmir's Aura</h1>Increases allies' lifesteal by %lifesteal_aura%%%, their damage by %damage_aura%%%, armor by %armor_aura% and mana regeneration by %mana_regen_aura%. <br><br>Radius: %aura_radius%\n<h1>Passive: Summon Power</h1>Increases summoned units' damage, health, attack speed and armor. Depends on your hero's attributes.Health increase per strength: %hp_bonus_per_str%%%<br>Damage increase per intelligence: %damage_bonus_per_int%%%<br>BAT reduction per agility: %speed_bonus_per_agi%<br>Armor increase per agility: %armor_bonus_per_agi%<br>Cleave damage (melee): %melee_splash%%%<br>Cleave damage (ranged): %ranged_splash%%%\n<h1>Passive: Free Ride</h1>Grants unobstructed movement to player-controlled units within 1000 radius. This effect cannot be dispelled, muted, or disabled in any way."
      "DOTA_Tooltip_ability_item_wraith_dominator_bonus_all_stats"                                                                "+$all"
      "DOTA_Tooltip_ability_item_wraith_dominator_bonus_health"                                                                   "+$health"
      "DOTA_Tooltip_ability_item_wraith_dominator_bonus_mana"                                                                     "+$mana"
      "DOTA_Tooltip_modifier_item_wraith_dominator_active_debuff"                                                                 "Wraith's Reprisal"
      "DOTA_Tooltip_modifier_item_wraith_dominator_active_debuff_Description"                                                     "Damage dealt reduced by %dMODIFIER_PROPERTY_TOTALDAMAGEOUTGOING_PERCENTAGE%%%"

      "DOTA_Tooltip_modifier_item_wraith_dominator_aura_buff"                                                                     "Vladmir's Aura"
      "DOTA_Tooltip_modifier_item_wraith_dominator_aura_buff_Description"                                                         "Has 18%% lifesteal, %dMODIFIER_PROPERTY_BASEDAMAGEOUTGOING_PERCENTAGE%%% bonus damage and %dMODIFIER_PROPERTY_PHYSICAL_ARMOR_BONUS% armor, and also restores %fMODIFIER_PROPERTY_MANA_REGEN_CONSTANT% mana per second."


      "DOTA_Tooltip_modifier_item_wraith_dominator_active_damage"                                                                 "Wraith of Dominator"
      "DOTA_Tooltip_modifier_item_wraith_dominator_active_damage_Description"                                                     "Increases allies' damage in 1200 radius"

      "DOTA_Tooltip_modifier_item_wraith_dominator_active_buff"                                                                   "Wraith of Dominator"
      "DOTA_Tooltip_modifier_item_wraith_dominator_active_buff_Description"                                                       "Outgoing damage increased by %dMODIFIER_PROPERTY_BONUSDAMAGEOUTGOING_PERCENTAGE%%%"
      "DOTA_Tooltip_modifier_item_wraith_dominator_active"                                                                       "Wraith of Dominator"
      "DOTA_Tooltip_modifier_item_wraith_dominator_active_Description"                                                           "Reduces all damage from enemies / increases allies' damage in radius and deals periodic damage to enemies"
      "DOTA_Tooltip_modifier_item_wraith_pact_custom_aura"                                                                       "Vladmir's Aura"
      "DOTA_Tooltip_modifier_item_wraith_pact_custom_aura_Description"                                                           "Has 24%% lifesteal, %dMODIFIER_PROPERTY_BASEDAMAGEOUTGOING_PERCENTAGE%%% bonus damage and %dMODIFIER_PROPERTY_PHYSICAL_ARMOR_BONUS% armor, and regenerates %dMODIFIER_PROPERTY_MANA_REGEN_CONSTANT% mana per second."
      "DOTA_Tooltip_modifier_item_wraith_pact_custom_debuff"                                                                     "Wraith's Reprisal"
      "DOTA_Tooltip_modifier_item_wraith_pact_custom_debuff_Description"                                                         "All outgoing damage reduced by %dMODIFIER_PROPERTY_TOTALDAMAGEOUTGOING_PERCENTAGE%%%"
      "npc_dota_item_wraith_pact_totem"                                                                                          "Wraith Pact Totem"

      "DOTA_Tooltip_Ability_item_apex_custom"                                                                                     "Apex"
      "DOTA_Tooltip_Ability_item_apex_custom_Lore"                                                                                "This scepter combines three spheres of exceptional power."
      "DOTA_Tooltip_Ability_item_apex_custom_Description"                                                                         "<h1>Passive:</h1>Universal heroes gain +%stats_all% to all attributes instead.\n\n<h1>Stats:</h1>+%primary_stat% to primary attribute<br>+%bonus_stats% to other attributes"
    // Bonus stat labels intentionally omitted — values inline in Description's «Stats:».

      "DOTA_Tooltip_Ability_item_revenants_brooch_custom"                                                                         "Revenant's Brooch"
      "DOTA_Tooltip_ability_item_revenants_brooch_custom_bonus_damage"                                                            "+$damage"
      "DOTA_Tooltip_ability_item_revenants_brooch_custom_spell_lifesteal"                                                         "%+$spell_lifesteal"

      "DOTA_Tooltip_modifier_misery_debuff_custom"                                                                                "Revenant's Wail"
    "DOTA_Tooltip_modifier_misery_debuff_custom_Description"                                                                      "Magic resistance reduced by %dMODIFIER_PROPERTY_MAGICAL_RESISTANCE_BONUS%%."

      "DOTA_Tooltip_modifier_item_revenants_brooch_custom_counter"                                                                "Revenant's Brooch"
    "DOTA_Tooltip_modifier_item_revenants_brooch_custom_counter_Description"                                                      "Attacks cannot miss and deal magical damage."
      
      "DOTA_Tooltip_Ability_item_seer_stone_custom"                                                                               "Seer Stone"
      "DOTA_Tooltip_ability_item_seer_stone_custom_Description"                                                                   "<h1>Active: Reveal</h1>Grants vision in any area with %radius% radius for %duration% sec, revealing invisibility."
      "DOTA_Tooltip_ability_item_seer_stone_custom_Lore"                                                                          "A curious creation of a sorcerer who chose connection with another time as their path."
      "DOTA_Tooltip_ability_item_seer_stone_custom_cast_range_bonus"                                                              "+$cast_range"
      "DOTA_Tooltip_ability_item_seer_stone_custom_vision_bonus"                                                                  "+vision range"
      "DOTA_Tooltip_ability_item_seer_stone_custom_mana_regen"                                                                    "+$mana_regen"
      "DOTA_Tooltip_ability_item_seer_stone_custom_cooldown"                                                                      "%+$cooldown_reduction"

      "DOTA_Tooltip_Ability_item_ex_machina_custom"                                                                               "Ex Machina"
      "DOTA_Tooltip_Ability_item_ex_machina_custom_Description"                                                                   "<h1>Active: Reset Cooldowns</h1>Resets cooldown of all items in inventory, including neutral slot. Does not refresh: Refresher Orb, Black King Bar, Ex Machina, Aeon Disk.\n\n<h1>Stats:</h1>+%bonus_armor% armor"
      "DOTA_Tooltip_Ability_item_ex_machina_custom_Lore"                                                                          "Remains of an ancient universe enclosed in a sphere."
    // Bonus stat labels intentionally omitted — values inline in Description's «Stats:».
      "DOTA_Tooltip_ability_item_ex_machina_custom_ability_note"                                                                  ""

      "DOTA_Tooltip_Ability_item_shivas_guard_2"                                                                                  "Shiva's Core"
      "DOTA_Tooltip_ability_item_shivas_guard_2_Description"                                                                      "<h1>Active: Arctic Blast</h1> Releases a freezing wave that deals %blast_damage% magical damage to enemies.<br>Applies an effect for %blast_debuff_duration% sec that reduces movement speed by %blast_movement_speed%%% and increases incoming magical damage by %discord_effect%%%.<br><br>Radius: %blast_radius%\n<h1>Passive: Freezing Aura</h1>Reduces enemies' attack speed by %aura_attack_speed%, and their healing, health regeneration and lifesteal by %hp_regen_degen_aura%%%.<br><br>Radius: %aura_radius%"
      "DOTA_Tooltip_ability_item_shivas_guard_2_Lore"                                                                             "They say this artifact once belonged to a goddess, and it has not lost its former power to this day."
      "DOTA_Tooltip_ability_item_shivas_guard_2_Note0"                                                                            "Wave spreads at speed of %blast_speed% to maximum size of %blast_radius%."
      "DOTA_Tooltip_ability_item_shivas_guard_2_Note1"                                                                            "Freezing wave follows the owner."
      "DOTA_Tooltip_ability_item_shivas_guard_2_Note2"                                                                            "Multiple Freezing Aura effects do not stack."
      "DOTA_Tooltip_ability_item_shivas_guard_2_bonus_intellect"                                                                  "+$int"
      "DOTA_Tooltip_ability_item_shivas_guard_2_bonus_armor"                                                                      "+$armor"
      "DOTA_Tooltip_ability_item_shivas_guard_2_bonus_castrange"                                                                  "+$cast_range"
      "DOTA_Tooltip_ability_item_shivas_guard_2_bonus_aoe"                                                                        "+$aoe_bonus"
      "DOTA_Tooltip_ability_item_shivas_guard_2_bonus_manaregen"                                                                  "+$mana_regen"
      "DOTA_Tooltip_ability_item_shivas_guard_2_bonus_health"                                                                     "+$health"
      "DOTA_Tooltip_ability_item_shivas_guard_2_bonus_mana"                                                                       "+$mana"
      "DOTA_Tooltip_ability_item_shivas_guard_2_bonus_cooldown"                                                                   "%+$cooldown_reduction"
      
      "DOTA_Tooltip_modifier_item_shivas_guard_2_aura"                                                                            "Freezing Aura"
      "DOTA_Tooltip_modifier_item_shivas_guard_2_aura_Description"                                                                "Attack speed reduced by %dMODIFIER_PROPERTY_ATTACKSPEED_BONUS_CONSTANT%, health regeneration reduced by %dMODIFIER_PROPERTY_LIFESTEAL_AMPLIFY_PERCENTAGE%%%."

      "DOTA_Tooltip_modifier_item_shivas_guard_2_debuff"                                                                          "Arctic Blast"
      "DOTA_Tooltip_modifier_item_shivas_guard_2_debuff_Description"                                                              "Movement speed reduced by %dMODIFIER_PROPERTY_MOVESPEED_BONUS_PERCENTAGE%%%."

      "DOTA_Tooltip_modifier_item_shivas_guard_2_discord_debuff"                                                                  "Magic Weakness"
      "DOTA_Tooltip_modifier_item_shivas_guard_2_discord_debuff_Description"                                                      "All incoming spell damage increased by %dMODIFIER_PROPERTY_MAGICAL_RESISTANCE_BONUS%%%."

      "DOTA_Tooltip_Ability_item_ghost_custom"                                                                                    "Ghost Scepter"
      "DOTA_Tooltip_ability_item_ghost_custom_Description"                                                                        "<h1>Active: Ghost Form</h1> Grants owner ethereal form, which completely protects from physical damage, but prevents attacking and increases magical damage taken by %extra_spell_damage_percent%%%. Lasts %duration% sec."
      "DOTA_Tooltip_ability_item_ghost_custom_Note0"                                                                              "Effect is dispelled by magic immunity and will not work through it."
      "DOTA_Tooltip_ability_item_ghost_custom_Note1"                                                                              "Shares cooldown with Ethereal Blade."
      "DOTA_Tooltip_ability_item_ghost_custom_bonus_all_stats"                                                                    "+$all"
      "DOTA_Tooltip_ability_item_ghost_custom_Lore"                                                                               "Transfers owner's essence to the spirit world, protecting from physical attacks."

      "DOTA_Tooltip_Ability_item_crellas_crozier"                                                                                 "Crella's Crozier"
      "DOTA_Tooltip_ability_item_crellas_crozier_Description"                                                                     "<h1>Active: Rite of Rumusque</h1>Enters ghost form for %duration% sec: immune to physical damage, cannot attack, takes %extra_spell_damage_percent%%% more magic damage. While active, steals %move_speed_steal%%% movement speed per second from enemy heroes in %aura_radius% radius (stacks, %move_speed_steal_duration% sec).\n\n<h1>Passive: Putrefaction Aura</h1>Reduces Health Restoration of nearby enemy heroes by %passive_health_restore_reduction%%%. Increased to %active_health_restore_reduction%%% while Rite of Rumusque is active.<br><br>Radius: %aura_radius%"
      "DOTA_Tooltip_ability_item_crellas_crozier_Note0"                                                                           "Ghost Form effect is dispelled by magic immunity and will not work through it."
      "DOTA_Tooltip_ability_item_crellas_crozier_Note1"                                                                           "Shares cooldown with Ethereal Blade."
      "DOTA_Tooltip_ability_item_crellas_crozier_bonus_strength"                                                                  "+$str"
      "DOTA_Tooltip_ability_item_crellas_crozier_bonus_agility"                                                                   "+$agi"
      "DOTA_Tooltip_ability_item_crellas_crozier_bonus_intellect"                                                                 "+$int"
      "DOTA_Tooltip_ability_item_crellas_crozier_bonus_health"                                                                    "+$health"
      "DOTA_Tooltip_ability_item_crellas_crozier_bonus_mana"                                                                      "+$mana"
      "DOTA_Tooltip_ability_item_crellas_crozier_Lore"                                                                            "A crozier once wielded by the high priest Crella, now imbued with rites that drain vitality from foes."

      "DOTA_Tooltip_modifier_item_crellas_crozier_aura_debuff"                                                                    "Putrefaction Aura"
      "DOTA_Tooltip_modifier_item_crellas_crozier_aura_debuff_Description"                                                        "Health Restoration reduced. Increased further while the Crella's Crozier owner is in Rite of Rumusque."

      "DOTA_Tooltip_modifier_item_crellas_crozier_ms_slow"                                                                        "Siphoned Stride"
      "DOTA_Tooltip_modifier_item_crellas_crozier_ms_slow_Description"                                                            "Movement speed drained by Crella's Crozier. Stacks."

      "DOTA_Tooltip_modifier_item_crellas_crozier_ms_steal"                                                                       "Rumusque's Pace"
      "DOTA_Tooltip_modifier_item_crellas_crozier_ms_steal_Description"                                                           "Movement speed gained from enemies drained by Rite of Rumusque. Stacks."

      // Removed info about percentage reduction for creeps lifesteal
      "DOTA_Tooltip_ability_item_satanic_Description"                                                                             "<h1>Active: Unholy Rage</h1> Increases lifesteal effect to %unholy_lifesteal_total_tooltip%%% for %unholy_duration% sec.<br><br>Dispel type: <span class=\"GameplayValues GameplayVariable\">normal</span> \n<h1>Passive: Lifesteal</h1>Each attack restores health to owner proportional to damage dealt."
      "DOTA_Tooltip_ability_item_lifesteal_Description"                                                                           "<h1>Passive: Lifesteal</h1> Grants owner's attacks lifesteal, restoring health proportional to damage dealt."
      "DOTA_Tooltip_ability_item_vladmir_Description"                                                                             "<h1>Passive: Vladmir's Aura</h1>Increases allies' lifesteal by %lifesteal_aura%%%, their damage by %damage_aura%%%, armor by %armor_aura% and mana regeneration by %mana_regen_aura%.<br><br>Radius: %aura_radius%"
      "DOTA_Tooltip_ability_item_wraith_pact_Description"                                                                         "<h1>Active: Wraith's Reprisal</h1>Summons a totem that reduces all damage from enemies in %pact_aura_radius% radius by %damage_penalty_aura%%% and deals %aura_dps% damage per second to them. Totem can move and exists for %abilityduration% sec.<br><br> Totem can be destroyed in 4 attacks. Creeps deal half normal damage to totem.\n<h1>Passive: Vladmir's Aura</h1>Increases allies' lifesteal by %lifesteal_aura%%%, their damage by %damage_aura%%%, armor by %armor_aura% and mana regeneration by %mana_regen_aura%. <br><br>Radius: %aura_radius%"
      "DOTA_Tooltip_ability_item_wraith_pact_custom"                                                                             "Wraith Pact"
      "DOTA_Tooltip_ability_item_wraith_pact_custom_bonus_health"                                                                "+$health"
      "DOTA_Tooltip_ability_item_wraith_pact_custom_bonus_mana"                                                                  "+$mana"
      "DOTA_Tooltip_ability_item_wraith_pact_custom_Description"                                                                 "<h1>Active: Wraith's Reprisal</h1>Summons a totem that reduces all damage from enemies in %pact_aura_radius% radius by %damage_penalty_aura%%% and deals %aura_dps% damage per second. The totem can move and lasts %abilityduration% sec.<br><br>The totem can be destroyed in 4 attacks. Creeps deal half damage to the totem.\n<h1>Passive: Vladmir's Aura</h1>Increases allies' lifesteal by %lifesteal_aura%%%, damage by %damage_aura%%%, armor by %armor_aura%, and mana regeneration by %mana_regen_aura%.<br><br>Radius: %aura_radius%"
      "DOTA_Tooltip_ability_item_helm_of_the_overlord_Description"                                                                "<h1>Active: Dominate</h1> Grants control over neutral creep and increases its movement speed to %speed_base%, and health pool to %health_min%. Also grants creep +%creep_bonus_damage% base damage, +%creep_bonus_armor% armor, +%creep_bonus_hp_regen% health regeneration and +%creep_bonus_mp_regen% mana regeneration.<br><br>If creature's maximum health is greater than %health_min%, it will not change. Killing creature grants %bounty_gold% gold.<br><br>Cast range: %abilitycastrange%\n<h1>Passive: Vladmir's Aura</h1>Increases nearby allies' lifesteal by %lifesteal_aura%%%, their damage by %damage_aura%%%, armor by %armor_aura% and mana regeneration by %mana_regen_aura%."
      "DOTA_Tooltip_ability_item_mask_of_madness_Description"                                                                     "<h1>Active: Berserk</h1> Grants owner %berserk_bonus_attack_speed% attack speed and %berserk_bonus_movement_speed% movement speed, but reduces armor by %berserk_armor_reduction% and prevents using abilities. Lasts %berserk_duration% sec.\n<h1>Passive: Lifesteal</h1> Grants owner's attacks lifesteal, restoring health proportional to damage dealt."
      "DOTA_Tooltip_Ability_item_paladin_sword_Description"                                                                       "<h1>Passive: Greater Healing</h1> Increases health gained from regeneration, healing and lifesteal by %bonus_amp%%%."

      "DOTA_Tooltip_Ability_item_fusion_rune_custom"                                                                              "Fusion Rune"
      "DOTA_Tooltip_ability_item_fusion_rune_custom_Description"                                                                  "<h1>Use: Consume</h1> Consumes one charge and grants allied unit effects of all power runes for %duration% sec."
      "DOTA_Tooltip_modifier_rune_arcane_custom"                                                                                  "Arcane Rune"
      "DOTA_Tooltip_modifier_rune_arcane_custom_Description"                                                                      "Cooldown reduced by 10%%, mana cost reduced by 30%%."

      "DOTA_Tooltip_ability_item_summoner_crown_1"                                                                                "Mask of Dominator"
      "DOTA_Tooltip_ability_item_summoner_crown_1_Description"                                                                    "<h1>Passive: Summon Power</h1>Increases summoned units' damage, health, attack speed and armor. Depends on your hero's attributes.Health increase per strength: %hp_bonus_per_str%%%<br>Damage increase per intelligence: %damage_bonus_per_int%%%<br>BAT reduction per agility: %speed_bonus_per_agi%<br>Armor increase per agility: %armor_bonus_per_agi%"
      "DOTA_Tooltip_ability_item_summoner_crown_1_bonus_all_stats"                                                                "+$all"

      "DOTA_Tooltip_ability_item_summoner_crown_2"                                                                                "Hood of Dominator"
      "DOTA_Tooltip_ability_item_summoner_crown_2_Description"                                                                    "<h1>Passive: Summon Power</h1>Increases summoned units' damage, health, attack speed and armor. Depends on your hero's attributes.Health increase per strength: %hp_bonus_per_str%%%<br>Damage increase per intelligence: %damage_bonus_per_int%%%<br>BAT reduction per agility: %speed_bonus_per_agi%<br>Armor increase per agility: %armor_bonus_per_agi%\n<h1>Passive: Free Ride</h1>Grants unobstructed movement to player-controlled units within 1000 radius. This effect cannot be dispelled, muted, or disabled in any way."
      "DOTA_Tooltip_ability_item_summoner_crown_2_bonus_all_stats"                                                                "+$all"
      "DOTA_Tooltip_modifier_summon_flying_movement_aura"                                                                        "Unobstructed Movement Aura"
      "DOTA_Tooltip_modifier_summon_flying_movement_aura_Description"                                                            "Grants unobstructed movement to player-controlled units within 1000 radius."
      "DOTA_Tooltip_modifier_summon_flying_movement_buff"                                                                         "Unobstructed Movement"
      "DOTA_Tooltip_modifier_summon_flying_movement_buff_Description"                                                             "Can move through obstacles and terrain. This effect cannot be dispelled, muted, or disabled."
    
      "DOTA_Tooltip_ability_item_summoner_crown_3"                                                                                "Crown of Dominator"
      "DOTA_Tooltip_ability_item_summoner_crown_3_Description"                                                                    "<h1>Passive: Summon Power</h1>Increases summoned units' damage, health, attack speed and armor. Depends on your hero's attributes.Health increase per strength: %hp_bonus_per_str%%%<br>Damage increase per intelligence: %damage_bonus_per_int%%%<br>BAT reduction per agility: %speed_bonus_per_agi%<br>Armor increase per agility: %armor_bonus_per_agi%\n<h1>Passive: Free Ride</h1>Grants unobstructed movement to player-controlled units within 1000 radius. This effect cannot be dispelled, muted, or disabled in any way."
      "DOTA_Tooltip_ability_item_summoner_crown_3_bonus_all_stats"                                                                "+$all"

      "DOTA_Tooltip_ability_item_relearn_torn_page_lua"                                                                           "Torn Page of Retraining Book"
      "DOTA_Tooltip_ability_item_relearn_torn_page_lua_Description"                                                               "<h1>Use: Retraining</h1>Changes your random ability to another"

      "DOTA_Tooltip_ability_item_paragon_book"                                                                                    "Book of Paragon"
      "DOTA_Tooltip_ability_item_paragon_book_Description"                                                                        "<h1>Use: Improvement</h1>Grants you +1 ability permanently<br><br>Can only be used once per game."
      "DOTA_Tooltip_ability_item_paragon_book_lore"                                                                               "A secret tome containing a fragment of the Lord of Darkness' soul. Any who gaze upon its pages unlock their true potential."

      "DOTA_Tooltip_ability_item_paragon_book_2"                                                                                  "Book of Paragon 2"
      "DOTA_Tooltip_ability_item_paragon_book_2_Description"                                                                      "<h1>Use: Improvement</h1>Grants you +1 ability permanently<br><br>Item available at round 70<br>Can only be used once per game."
      "DOTA_Tooltip_ability_item_paragon_book_2_lore"                                                                             "A secret tome containing a fragment of the Lord of Darkness' soul. Any who gaze upon its pages unlock their true potential."

      "DOTA_Tooltip_ability_item_rune_forge"                                                                                      "Unstable Rune"
      "DOTA_Tooltip_ability_item_rune_forge_Description"                                                                          "<h1>Active: Rune Forge</h1>Creates random rune near hero. Cannot be used at base"

      "DOTA_Tooltip_ability_item_recipe_kaya_2_lua"                                                                               "Recipe: Sky Staff"
